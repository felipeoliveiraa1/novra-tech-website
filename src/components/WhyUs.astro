---
import Icon from './Icon.astro';

const pillars = [
  {
    icon: 'spark',
    title: 'Inovação Contínua',
    desc: 'Mantemos o seu negócio à frente da curva, aplicando as tecnologias mais recentes e eficazes — sempre com propósito, governança e resultado.',
  },
  {
    icon: 'handshake',
    title: 'Parceria Estratégica',
    desc: 'Trabalhamos como uma extensão do seu time. Entendemos suas dores, antecipamos riscos e construímos as soluções que realmente importam.',
  },
  {
    icon: 'target',
    title: 'Excelência de Engenharia',
    desc: 'Compromisso com entregas de alto padrão: código limpo, performance impecável, segurança por design e suporte contínuo.',
  },
  {
    icon: 'pulse',
    title: 'Resultados Mensuráveis',
    desc: 'Definimos métricas claras desde o início e entregamos impacto positivo com retorno sobre o investimento comprovado.',
  },
];
---
<section class="section why" id="diferenciais">
  <span class="glow-orb why__orb" aria-hidden="true"></span>
  <div class="container why__inner">
    <div class="why__intro">
      <div class="section-head" data-reveal>
        <span class="eyebrow">Por que Novra</span>
        <h2 class="h2 balance">Não somos fornecedores. Somos <span class="text-gradient">arquitetos</span> do seu futuro digital.</h2>
        <p class="lead pretty">
          Trabalhamos lado a lado com líderes que não aceitam mediocridade. Cada decisão
          de engenharia é guiada por um único objetivo: gerar impacto real e duradouro
          no seu negócio.
        </p>
      </div>
      <a href="#contato" class="link-arrow why__link" data-reveal data-magnetic>
        Conversar com a Novra <Icon name="arrow-right" size={18} />
      </a>
    </div>

    <div class="why__grid">
      {pillars.map((p, i) => (
        <article class="why__pillar" data-reveal style={`--reveal-delay: ${i * 90}ms`}>
          <span class="why__icon"><Icon name={p.icon} size={24} /></span>
          <h3 class="why__title">{p.title}</h3>
          <p class="why__desc">{p.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .why { position: relative; z-index: 2; overflow: hidden; }
  .why__orb {
    top: 30%; left: -10%;
    width: 40vw; height: 40vw; max-width: 560px; max-height: 560px;
    background: radial-gradient(circle, rgba(42, 91, 255, 0.22), transparent 65%);
  }
  .why__inner {
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2.5rem, 1.5rem + 4vw, 4.5rem);
  }
  .why__intro { display: flex; flex-direction: column; }
  .why__link { margin-top: 1.8rem; }

  .why__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    overflow: hidden;
  }
  .why__pillar {
    background: var(--bg-1);
    padding: clamp(1.6rem, 1.2rem + 1.5vw, 2.2rem);
    transition: background 0.5s var(--ease-out);
  }
  .why__pillar:hover { background: var(--bg-2); }
  .why__icon {
    display: grid; place-items: center;
    width: 50px; height: 50px;
    border-radius: 13px;
    background: linear-gradient(160deg, rgba(42, 91, 255, 0.2), rgba(0, 194, 255, 0.06));
    border: 1px solid var(--border-brand);
    color: var(--cyan-300);
    margin-bottom: 1.2rem;
  }
  .why__title { font-size: 1.15rem; margin-bottom: 0.6rem; }
  .why__desc { font-size: 0.94rem; color: var(--text-2); line-height: 1.6; }

  @media (min-width: 620px) {
    .why__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1000px) {
    .why__inner { grid-template-columns: 0.9fr 1.1fr; align-items: start; }
    .why__intro { position: sticky; top: 7rem; }
  }
</style>
