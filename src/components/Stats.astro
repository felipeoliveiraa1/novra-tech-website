---
// EDITE: ajuste os números para os valores reais da Novra Tech.
const stats = [
  { value: 120, prefix: '+', suffix: '', label: 'Projetos entregues', sub: 'do MVP à escala enterprise' },
  { value: 99.9, prefix: '', suffix: '%', label: 'Disponibilidade', sub: 'SLA de uptime em produção', decimals: 1 },
  { value: 8, prefix: '', suffix: ' anos', label: 'De experiência aplicada', sub: 'em sistemas de alta complexidade' },
  { value: 40, prefix: '+', suffix: '', label: 'Especialistas sênior', sub: 'engenharia, dados, IA e produto' },
];
---
<section class="section-sm stats" id="provas">
  <div class="container">
    <div class="stats__grid">
      {stats.map((s, i) => (
        <div class="stat" data-reveal style={`--reveal-delay: ${i * 90}ms`}>
          <div class="stat__value">
            <span class="stat__prefix">{s.prefix}</span>
            <span
              class="stat__num"
              data-count={s.value}
              data-decimals={s.decimals ?? 0}
              data-suffix={s.suffix}
            >0{s.suffix}</span>
          </div>
          <div class="stat__label">{s.label}</div>
          <div class="stat__sub">{s.sub}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .stats { position: relative; z-index: 2; }
  .stats__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    overflow: hidden;
  }
  .stat {
    background: var(--bg-1);
    padding: clamp(1.6rem, 1rem + 2vw, 2.6rem) clamp(1.4rem, 1rem + 1.5vw, 2.2rem);
    position: relative;
    transition: background 0.5s var(--ease-out);
  }
  .stat::before {
    content: ""; position: absolute; top: 0; left: 0; width: 100%; height: 2px;
    background: var(--grad-brand); transform: scaleX(0); transform-origin: left;
    transition: transform 0.6s var(--ease-out);
  }
  .stat:hover { background: var(--bg-2); }
  .stat:hover::before { transform: scaleX(1); }
  .stat__value {
    display: flex; align-items: baseline;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(2.6rem, 1.6rem + 4vw, 4.2rem);
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--text-1);
  }
  .stat__prefix { color: var(--cyan-400); font-size: 0.7em; margin-right: 0.05em; }
  .stat__num {
    background: linear-gradient(160deg, #ffffff 0%, #9cd4ff 55%, var(--cyan-500) 100%);
    -webkit-background-clip: text; background-clip: text; color: transparent;
    filter: drop-shadow(0 4px 24px rgba(0, 160, 255, 0.25));
  }
  .stat__label { margin-top: 0.9rem; font-family: var(--font-display); font-weight: 500; color: var(--text-1); font-size: 1.02rem; }
  .stat__sub { margin-top: 0.3rem; font-size: 0.86rem; color: var(--text-3); }

  @media (min-width: 760px) {
    .stats__grid { grid-template-columns: repeat(4, 1fr); }
  }
</style>
