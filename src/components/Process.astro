---
import Icon from './Icon.astro';

const steps = [
  {
    icon: 'search',
    title: 'Diagnóstico & Estratégia',
    desc: 'Imersão no seu negócio. Mapeamos objetivos, restrições e riscos para definir o caminho de maior impacto — antes de escrever uma linha de código.',
  },
  {
    icon: 'blueprint',
    title: 'Arquitetura & Blueprint',
    desc: 'Desenhamos a arquitetura, o plano de entrega e os critérios de sucesso. Você sabe exatamente o que será construído, quando e por quê.',
  },
  {
    icon: 'rocket',
    title: 'Engenharia & Entrega',
    desc: 'Squads sênior em ciclos curtos, com qualidade, testes e segurança desde o primeiro commit. Entregas contínuas e visibilidade total do progresso.',
  },
  {
    icon: 'infinity',
    title: 'Evolução & Operação',
    desc: 'Monitoramento, otimização e evolução contínua. Operamos lado a lado com o seu time para garantir performance e ROI no longo prazo.',
  },
];
---
<section class="section process" id="processo">
  <span class="glow-orb process__orb" aria-hidden="true"></span>
  <div class="container">
    <div class="section-head" data-reveal>
      <span class="eyebrow">Como trabalhamos</span>
      <h2 class="h2 balance">Um processo desenhado para reduzir risco e <span class="text-gradient">acelerar resultado</span></h2>
      <p class="lead pretty">
        Metodologia transparente, do primeiro diagnóstico à operação contínua.
        Sem caixas-pretas — você acompanha cada decisão e cada métrica.
      </p>
    </div>

    <ol class="process__grid">
      <span class="process__line" aria-hidden="true"></span>
      {steps.map((s, i) => (
        <li class="process__step" data-reveal style={`--reveal-delay: ${i * 110}ms`}>
          <article class="process__card card">
            <div class="process__top">
              <span class="process__num">{String(i + 1).padStart(2, '0')}</span>
              <span class="process__icon"><Icon name={s.icon} size={22} /></span>
            </div>
            <h3 class="process__title">{s.title}</h3>
            <p class="process__desc">{s.desc}</p>
          </article>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .process { position: relative; z-index: 2; overflow: hidden; }
  .process__orb {
    top: 18%; right: -8%;
    width: 38vw; height: 38vw; max-width: 540px; max-height: 540px;
    background: radial-gradient(circle, rgba(0, 160, 255, 0.16), transparent 66%);
  }
  .process .section-head { margin-bottom: clamp(2.8rem, 2rem + 3vw, 4.5rem); }
  .process__grid {
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.1rem;
  }
  .process__line { display: none; }
  .process__step { position: relative; list-style: none; }
  .process__card {
    height: 100%;
    padding: clamp(1.5rem, 1.2rem + 1vw, 2rem);
  }
  .process__top {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 1.4rem;
  }
  .process__num {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.6rem, 1.8rem + 3vw, 3.6rem);
    line-height: 1;
    letter-spacing: -0.04em;
    background: linear-gradient(160deg, #ffffff, #4f8cff 60%, var(--cyan-500));
    -webkit-background-clip: text; background-clip: text; color: transparent;
    opacity: 0.95;
  }
  .process__icon {
    display: grid; place-items: center;
    width: 50px; height: 50px;
    border-radius: 13px;
    background: linear-gradient(160deg, rgba(42, 91, 255, 0.22), rgba(0, 194, 255, 0.08));
    border: 1px solid var(--border-brand);
    color: var(--cyan-300);
    transition: transform 0.5s var(--ease-out), box-shadow 0.5s var(--ease-out);
  }
  .process__card:hover .process__icon { transform: translateY(-3px); box-shadow: var(--glow-cyan); }
  .process__title { font-size: 1.18rem; margin-bottom: 0.7rem; }
  .process__desc { font-size: 0.94rem; color: var(--text-2); line-height: 1.6; }

  @media (min-width: 620px) {
    .process__grid { grid-template-columns: repeat(2, 1fr); gap: 1.1rem; }
  }
  @media (min-width: 1040px) {
    .process__grid { grid-template-columns: repeat(4, 1fr); gap: 1.1rem; }
    .process__line {
      display: block;
      position: absolute;
      top: -1px; left: 8%; right: 8%;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--blue-500) 15%, var(--cyan-500) 85%, transparent);
      opacity: 0.5;
      z-index: 3;
    }
  }
</style>
