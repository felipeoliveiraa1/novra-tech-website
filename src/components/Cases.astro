---
import Icon from './Icon.astro';

// EDITE: substitua por cases reais (imagens, títulos e resultados).
const cases = [
  {
    img: '/img/case-infra.jpg',
    tag: 'Cloud & Modernização',
    title: 'Modernização de core de missão crítica',
    result: '−63% de custo de infraestrutura, com 99,99% de disponibilidade.',
  },
  {
    img: '/img/case-ai.jpg',
    tag: 'Inteligência Artificial',
    title: 'Copiloto de IA em produção',
    result: '+40% de produtividade operacional e respostas em < 120ms.',
  },
  {
    img: '/img/case-data.jpg',
    tag: 'Dados & Analytics',
    title: 'Plataforma de dados em tempo real',
    result: 'Decisões 8× mais rápidas a partir de dados unificados.',
  },
];
---
<section class="section cases" id="cases">
  <span class="glow-orb cases__orb" aria-hidden="true"></span>
  <div class="container">
    <div class="cases__head">
      <div class="section-head" data-reveal>
        <span class="eyebrow">Cases &amp; resultados</span>
        <h2 class="h2 balance">Transformações que geram <span class="text-gradient">impacto real</span></h2>
      </div>
      <p class="lead pretty cases__intro" data-reveal style="--reveal-delay: 120ms">
        Da estratégia à operação, entregamos resultados mensuráveis para empresas
        que não podem parar. Veja alguns exemplos do que construímos.
      </p>
    </div>

    <div class="cases__grid">
      {cases.map((c, i) => (
        <article class="case" data-reveal style={`--reveal-delay: ${i * 100}ms`}>
          <div class="case__media">
            <img src={c.img} alt={c.title} loading="lazy" decoding="async" width="900" height="680" />
            <span class="case__scrim"></span>
            <span class="case__tag"><span class="dot"></span>{c.tag}</span>
          </div>
          <div class="case__body">
            <h3 class="case__title">{c.title}</h3>
            <p class="case__result">{c.result}</p>
            <span class="case__link link-arrow">Ver detalhes <Icon name="arrow-up-right" size={16} /></span>
          </div>
          <span class="case__accent" aria-hidden="true"></span>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .cases { position: relative; z-index: 2; overflow: hidden; }
  .cases__orb {
    top: 10%; right: -10%;
    width: 44vw; height: 44vw; max-width: 620px; max-height: 620px;
    background: radial-gradient(circle, rgba(0, 168, 255, 0.14), transparent 66%);
  }
  .cases__head {
    display: grid; grid-template-columns: 1fr; gap: 1.4rem; align-items: end;
    margin-bottom: clamp(2.5rem, 1.5rem + 3vw, 4rem);
  }
  .cases__intro { max-width: 460px; }

  .cases__grid { display: grid; grid-template-columns: 1fr; gap: 1.4rem; }
  .case {
    position: relative;
    border-radius: var(--r-lg);
    border: 1px solid var(--border);
    background: linear-gradient(180deg, var(--surface-2), var(--surface));
    overflow: hidden;
    transition: border-color 0.5s var(--ease-out), transform 0.5s var(--ease-out);
  }
  .case:hover { border-color: var(--border-brand); transform: translateY(-4px); }
  .case__media { position: relative; aspect-ratio: 16 / 10; overflow: hidden; }
  .case__media img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.7s var(--ease-out);
  }
  .case:hover .case__media img { transform: scale(1.06); }
  .case__scrim {
    position: absolute; inset: 0;
    background: linear-gradient(180deg, rgba(5,7,14,0) 35%, rgba(5,7,14,0.25) 72%, rgba(11,15,28,0.92) 100%);
  }
  .case__accent {
    position: absolute; left: 0; right: 0; top: 0; height: 2px; z-index: 4;
    background: var(--grad-brand); transform: scaleX(0); transform-origin: left;
    transition: transform 0.6s var(--ease-out);
  }
  .case:hover .case__accent { transform: scaleX(1); }
  .case__tag {
    position: absolute; top: 1rem; left: 1rem;
    display: inline-flex; align-items: center; gap: 0.5em;
    padding: 0.45em 0.85em;
    border-radius: var(--r-pill);
    background: rgba(8, 11, 20, 0.7);
    backdrop-filter: blur(8px);
    border: 1px solid var(--border-strong);
    font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.04em; color: var(--text-1);
  }
  .case__tag .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--cyan-400); box-shadow: 0 0 8px var(--cyan-400); }
  .case__body { padding: 1.4rem 1.5rem 1.6rem; margin-top: -2.5rem; position: relative; }
  .case__title { font-size: 1.22rem; line-height: 1.22; margin-bottom: 0.6rem; }
  .case__result { font-size: 0.94rem; color: var(--text-2); line-height: 1.55; }
  .case__link { margin-top: 1.1rem; font-size: 0.92rem; }

  @media (min-width: 720px) {
    .cases__grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (min-width: 900px) {
    .cases__head { grid-template-columns: 1.4fr 1fr; }
  }
</style>
