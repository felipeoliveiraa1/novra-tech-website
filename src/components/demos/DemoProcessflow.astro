---
// ProcessFlow — torre de controle logística: mapa vivo com frota em movimento,
// feed de eventos em tempo real e otimização de rotas por IA sob demanda.
---
<section class="demo pw" id="demo-processflow" data-demo="processflow" hidden>
  <div class="pw-grid">
    <div class="pw-mapcol">
      <div class="pw-maphead">
        <h4>Malha em tempo real <span class="pw-live"><i></i> ao vivo</span></h4>
        <span class="pw-maphead__s">6 hubs · 312 rotas ativas · 148 veículos</span>
      </div>
      <svg class="pw-map" viewBox="0 0 720 520" aria-hidden="true">
        <defs>
          <radialGradient id="gp-glow" cx="0.5" cy="0.5" r="0.5">
            <stop offset="0" stop-color="rgba(46,107,255,0.35)"/><stop offset="1" stop-color="rgba(46,107,255,0)"/>
          </radialGradient>
        </defs>
        <!-- território estilizado -->
        <path class="pw-land" d="M300,42 L430,56 L505,92 L640,150 L662,196 L618,258 L560,330 L512,392 L432,470 L368,502 L330,458 L302,398 L252,330 L204,262 L212,158 L254,88 Z"/>
        <g class="pw-dots" fill="rgba(120,158,255,0.14)">
          <circle cx="300" cy="150" r="2"/><circle cx="360" cy="120" r="2"/><circle cx="420" cy="140" r="2"/><circle cx="480" cy="170" r="2"/>
          <circle cx="330" cy="220" r="2"/><circle cx="390" cy="190" r="2"/><circle cx="540" cy="220" r="2"/><circle cx="580" cy="180" r="2"/>
          <circle cx="280" cy="280" r="2"/><circle cx="350" cy="300" r="2"/><circle cx="500" cy="260" r="2"/><circle cx="440" cy="300" r="2"/>
          <circle cx="380" cy="360" r="2"/><circle cx="460" cy="400" r="2"/><circle cx="340" cy="420" r="2"/><circle cx="400" cy="450" r="2"/>
        </g>
        <circle cx="430" cy="350" r="90" fill="url(#gp-glow)"/>

        <!-- rotas atuais -->
        <g class="pw-routes pw-routes--a">
          <path id="pw-ra1" class="pw-route" d="M430,350 C 455,345 485,340 510,330"/>
          <path id="pw-ra2" class="pw-route" d="M430,350 C 445,330 465,315 480,300"/>
          <path id="pw-ra3" class="pw-route" d="M430,350 C 420,375 410,395 400,410"/>
          <path id="pw-ra4" class="pw-route" d="M430,350 C 425,310 422,270 420,240"/>
          <path class="pw-route" d="M420,240 C 480,215 545,200 600,190"/>
          <path class="pw-route pw-route--alert" d="M430,350 C 470,365 495,350 510,330"/>
          <path id="pw-ra5" class="pw-route" d="M400,410 C 390,432 380,452 370,470"/>
        </g>
        <!-- rotas otimizadas (entram na otimização) -->
        <g class="pw-routes pw-routes--b">
          <path id="pw-rb1" class="pw-route pw-route--opt" d="M430,350 C 460,330 490,325 510,330"/>
          <path id="pw-rb2" class="pw-route pw-route--opt" d="M430,350 C 500,300 560,240 600,190"/>
          <path id="pw-rb3" class="pw-route pw-route--opt" d="M430,350 C 405,390 385,435 370,470"/>
          <path class="pw-route pw-route--opt" d="M430,350 C 440,315 435,270 420,240"/>
          <path class="pw-route pw-route--opt" d="M430,350 C 448,328 465,312 480,300"/>
        </g>

        <!-- frota A (rotas atuais) -->
        <g class="pw-fleet pw-fleet--a">
          <circle class="pw-truck" r="4"><animateMotion dur="6s" repeatCount="indefinite"><mpath href="#pw-ra1"/></animateMotion></circle>
          <circle class="pw-truck" r="4"><animateMotion dur="8s" repeatCount="indefinite"><mpath href="#pw-ra4"/></animateMotion></circle>
          <circle class="pw-truck" r="4"><animateMotion dur="7s" repeatCount="indefinite" begin="1.2s"><mpath href="#pw-ra3"/></animateMotion></circle>
          <circle class="pw-truck" r="4"><animateMotion dur="9s" repeatCount="indefinite" begin="2s"><mpath href="#pw-ra5"/></animateMotion></circle>
        </g>
        <!-- frota B (rotas otimizadas) -->
        <g class="pw-fleet pw-fleet--b">
          <circle class="pw-truck pw-truck--opt" r="4"><animateMotion dur="5s" repeatCount="indefinite"><mpath href="#pw-rb1"/></animateMotion></circle>
          <circle class="pw-truck pw-truck--opt" r="4"><animateMotion dur="7s" repeatCount="indefinite" begin="0.8s"><mpath href="#pw-rb2"/></animateMotion></circle>
          <circle class="pw-truck pw-truck--opt" r="4"><animateMotion dur="6s" repeatCount="indefinite" begin="1.6s"><mpath href="#pw-rb3"/></animateMotion></circle>
        </g>

        <!-- hubs (clicáveis: mostram o painel da praça) -->
        <g class="pw-hubs">
          <g class="pw-hubg" data-action="pw-hub" data-hub="sp" transform="translate(430,350)"><circle class="pw-hit" r="18"/><circle class="pw-hub pw-hub--main" r="8"/><text class="pw-lbl" x="-14" y="24">CD Central · SP</text></g>
          <g class="pw-hubg" data-action="pw-hub" data-hub="rj" transform="translate(510,330)"><circle class="pw-hit" r="15"/><circle class="pw-hub" r="5"/><text class="pw-lbl" x="10" y="4">RJ</text></g>
          <g class="pw-hubg" data-action="pw-hub" data-hub="bh" transform="translate(480,300)"><circle class="pw-hit" r="15"/><circle class="pw-hub" r="5"/><text class="pw-lbl" x="9" y="-6">BH</text></g>
          <g class="pw-hubg" data-action="pw-hub" data-hub="bsb" transform="translate(420,240)"><circle class="pw-hit" r="15"/><circle class="pw-hub" r="5"/><text class="pw-lbl" x="10" y="4">BSB</text></g>
          <g class="pw-hubg" data-action="pw-hub" data-hub="rec" transform="translate(600,190)"><circle class="pw-hit" r="15"/><circle class="pw-hub" r="5"/><text class="pw-lbl" x="10" y="4">REC</text></g>
          <g class="pw-hubg" data-action="pw-hub" data-hub="cwb" transform="translate(400,410)"><circle class="pw-hit" r="15"/><circle class="pw-hub" r="5"/><text class="pw-lbl" x="-38" y="4">CWB</text></g>
          <g class="pw-hubg" data-action="pw-hub" data-hub="poa" transform="translate(370,470)"><circle class="pw-hit" r="15"/><circle class="pw-hub" r="5"/><text class="pw-lbl" x="-40" y="4">POA</text></g>
        </g>
      </svg>
      <p class="pw-hint">Toque em um hub do mapa para ver a praça em detalhe.</p>
      <div class="pw-entregas">
        <h4>Entregas em andamento</h4>
        <table class="pw-table">
          <thead><tr><th>Pedido</th><th>Rota</th><th>Motorista</th><th>Chega em</th><th>Status</th></tr></thead>
          <tbody>
            <tr data-late><td class="mono">#8.451</td><td>SP → RJ</td><td>Carlos M.</td><td class="pw-eta" data-eta-antes="2h40" data-eta-depois="1h55">2h40</td><td><span class="pw-st pw-st--late">atrasando</span><span class="pw-st pw-st--ok">no prazo</span></td></tr>
            <tr><td class="mono">#8.452</td><td>SP → BH</td><td>Ana P.</td><td class="pw-eta" data-eta-antes="3h10" data-eta-depois="2h48">3h10</td><td><span class="pw-st pw-st--ok">no prazo</span></td></tr>
            <tr><td class="mono">#8.449</td><td>BSB → REC</td><td>Jorge L.</td><td class="pw-eta" data-eta-antes="5h20" data-eta-depois="4h35">5h20</td><td><span class="pw-st pw-st--ok">no prazo</span></td></tr>
            <tr><td class="mono">#8.455</td><td>SP → CWB</td><td>Renata S.</td><td class="pw-eta" data-eta-antes="1h45" data-eta-depois="1h30">1h45</td><td><span class="pw-st pw-st--ok">no prazo</span></td></tr>
          </tbody>
        </table>
      </div>
      <div class="pw-toastzone"></div>
    </div>

    <aside class="pw-side">
      <div class="pw-hubcard" hidden>
        <div class="pw-hubcard__h"><b class="pw-hubcard__nome">—</b><button class="pw-hubcard__x" data-action="pw-hub-close" type="button" aria-label="Fechar">✕</button></div>
        <div class="pw-hubcard__grid">
          <div><span>Entregas hoje</span><b class="pw-hubcard__ent">—</b></div>
          <div><span>Veículos ativos</span><b class="pw-hubcard__vei">—</b></div>
          <div><span>Ocupação da doca</span><b class="pw-hubcard__ocu">—</b></div>
          <div><span>Pontualidade</span><b class="pw-hubcard__pon">—</b></div>
        </div>
        <p class="pw-hubcard__nota">—</p>
      </div>
      <div class="pw-kpis">
        <div class="pw-kpi"><span>Entregas no prazo</span><b><i data-kpi="prazo">0</i>%</b><em data-kpid="prazo"></em></div>
        <div class="pw-kpi"><span>Custo por entrega</span><b><i data-kpi="custo">0</i></b><em data-kpid="custo">índice base 100</em></div>
        <div class="pw-kpi"><span>Ocupação da frota</span><b><i data-kpi="ocupacao">0</i>%</b><em data-kpid="ocupacao"></em></div>
      </div>

      <button class="pw-optimize btn btn-primary" data-action="pw-optimize" type="button">
        <span class="pw-optimize__label">✦ Otimizar rotas com IA</span>
      </button>

      <div class="pw-feedbox">
        <h4>Eventos <span class="pw-live"><i></i> tempo real</span></h4>
        <ul class="pw-feed"></ul>
      </div>
    </aside>
  </div>
</section>

<style is:global>
  .pw { padding: clamp(0.9rem, 2.5vw, 1.6rem); background: #0a0b10; min-height: 100%; display: flex; }
  .pw-grid { display: grid; grid-template-columns: minmax(0, 1.6fr) minmax(0, 1fr); gap: 1rem; max-width: 1160px; margin: auto; width: 100%; }

  .pw-mapcol { position: relative; border: 1px solid var(--border-strong); border-radius: 16px; overflow: hidden; background: #0b0d13; padding: 1rem 1.1rem; min-width: 0; }
  .pw-maphead { display: flex; align-items: baseline; justify-content: space-between; gap: 0.8rem; flex-wrap: wrap; }
  .pw-maphead h4 { font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--text-2); display: flex; align-items: center; gap: 0.7rem; }
  .pw-maphead__s { font-family: var(--font-mono); font-size: 0.6rem; color: var(--text-3); }
  .pw-live { display: inline-flex; align-items: center; gap: 0.35rem; font-size: 0.58rem; color: #79e2a0; text-transform: none; letter-spacing: 0.04em; }
  .pw-live i { width: 6px; height: 6px; border-radius: 50%; background: #79e2a0; box-shadow: 0 0 8px rgba(121,226,160,0.8); animation: pw-blink 1.6s ease-in-out infinite; }
  @keyframes pw-blink { 50% { opacity: 0.35; } }

  .pw-map { width: 100%; height: auto; max-height: 66vh; display: block; }
  .pw-land { fill: rgba(46, 107, 255, 0.045); stroke: rgba(120, 158, 255, 0.22); stroke-width: 1.2; stroke-linejoin: round; }
  .pw-route { fill: none; stroke: rgba(120, 170, 255, 0.5); stroke-width: 1.6; stroke-dasharray: 6 7; }
  .play .pw-routes--a .pw-route { animation: pw-dash 1.3s linear infinite; }
  @keyframes pw-dash { to { stroke-dashoffset: -26; } }
  .pw-route--alert { stroke: rgba(201, 162, 75, 0.85); stroke-width: 2; }
  .pw-route--opt { stroke: rgba(0, 220, 160, 0.65); }
  .pw-routes--b, .pw-fleet--b { opacity: 0; transition: opacity 0.9s var(--ease-out); }
  .pw-routes--a, .pw-fleet--a { transition: opacity 0.9s var(--ease-out); }
  [data-optimized] .pw-routes--b, [data-optimized] .pw-fleet--b { opacity: 1; }
  [data-optimized] .pw-routes--b .pw-route { animation: pw-dash 1.1s linear infinite; }
  [data-optimized] .pw-routes--a, [data-optimized] .pw-fleet--a { opacity: 0.12; }
  [data-optimized] .pw-route--alert { opacity: 0.2; }
  .pw-truck { fill: var(--blue-energy); filter: drop-shadow(0 0 6px rgba(0,168,255,0.9)); }
  .pw-truck--opt { fill: #35e0a8; filter: drop-shadow(0 0 6px rgba(53,224,168,0.9)); }
  .pw-hub { fill: #10131c; stroke: rgba(150, 185, 255, 0.75); stroke-width: 1.6; }
  .pw-hub--main { stroke: var(--blue-energy); stroke-width: 2; filter: drop-shadow(0 0 10px rgba(0,168,255,0.6)); }
  .pw-lbl { fill: #9aa7c0; font-family: var(--font-mono); font-size: 10.5px; letter-spacing: 0.04em; }

  /* hubs clicáveis */
  .pw-hubg { cursor: pointer; }
  .pw-hit { fill: transparent; }
  .pw-hubg:hover .pw-hub { stroke: var(--blue-energy); }
  .pw-hubg.is-sel .pw-hub { stroke: var(--gold); stroke-width: 2.4; filter: drop-shadow(0 0 10px rgba(201,162,75,0.7)); }
  .pw-hint { margin-top: 0.4rem; font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.04em; color: var(--text-3); }

  /* painel da praça */
  .pw-hubcard { border: 1px solid rgba(201,162,75,0.4); border-radius: 14px; padding: 0.85rem 0.95rem; background: rgba(201,162,75,0.05); animation: pw-feed-in 0.4s var(--ease-out); }
  .pw-hubcard__h { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.6rem; }
  .pw-hubcard__h b { font-family: var(--font-display); font-size: 0.95rem; }
  .pw-hubcard__x { border: 0; background: none; color: var(--text-3); cursor: pointer; font-size: 0.8rem; padding: 0.2rem 0.4rem; }
  .pw-hubcard__x:hover { color: var(--text-1); }
  .pw-hubcard__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem 0.8rem; }
  .pw-hubcard__grid span { display: block; font-size: 0.58rem; color: var(--text-3); }
  .pw-hubcard__grid b { display: block; font-family: var(--font-display); font-weight: 700; font-size: 1rem; color: var(--text-1); }
  .pw-hubcard__nota { margin-top: 0.6rem; font-size: 0.7rem; line-height: 1.5; color: var(--gold-light); }

  /* tabela de entregas */
  .pw-entregas { margin-top: 0.7rem; border-top: 1px solid var(--border); padding-top: 0.7rem; overflow-x: auto; }
  .pw-entregas h4 { font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--text-3); margin-bottom: 0.5rem; }
  .pw-table { width: 100%; border-collapse: collapse; font-size: 0.74rem; }
  .pw-table th { text-align: left; font-family: var(--font-mono); font-size: 0.56rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-3); padding: 0.3rem 0.5rem; border-bottom: 1px solid var(--border); }
  .pw-table td { padding: 0.45rem 0.5rem; border-bottom: 1px solid rgba(255,255,255,0.05); color: var(--text-2); white-space: nowrap; }
  .pw-table .mono { font-family: var(--font-mono); font-size: 0.66rem; }
  .pw-eta.is-melhor { color: #35e0a8; font-weight: 600; }
  .pw-st { font-family: var(--font-mono); font-size: 0.56rem; letter-spacing: 0.04em; padding: 0.2em 0.55em; border-radius: 99px; }
  .pw-st--ok { color: #79e2a0; border: 1px solid rgba(121,226,160,0.35); background: rgba(121,226,160,0.08); }
  .pw-st--late { color: #e9c268; border: 1px solid rgba(233,194,104,0.35); background: rgba(233,194,104,0.08); }
  /* linha atrasada: badge troca quando otimiza */
  tr[data-late] .pw-st--ok { display: none; }
  [data-optimized] tr[data-late] .pw-st--late { display: none; }
  [data-optimized] tr[data-late] .pw-st--ok { display: inline-block; }

  .pw-toastzone { position: absolute; left: 1rem; right: 1rem; bottom: 1rem; display: flex; flex-direction: column; gap: 0.5rem; pointer-events: none; }
  .pw-toast {
    align-self: flex-start;
    display: flex; align-items: center; gap: 0.6rem;
    border: 1px solid rgba(53, 224, 168, 0.4); border-radius: 12px;
    background: rgba(8, 30, 24, 0.92); backdrop-filter: blur(8px);
    padding: 0.65rem 0.95rem; font-size: 0.78rem; color: #d9ffef;
    opacity: 0; transform: translateY(10px);
    animation: pw-toast-in 0.5s var(--ease-out) forwards;
  }
  @keyframes pw-toast-in { to { opacity: 1; transform: none; } }
  .pw-toast b { color: #35e0a8; }

  .pw-side { display: flex; flex-direction: column; gap: 0.8rem; min-width: 0; }
  .pw-kpis { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.55rem; }
  .pw-kpi { border: 1px solid var(--border); border-radius: 12px; padding: 0.7rem 0.75rem; background: rgba(255,255,255,0.016); min-width: 0; }
  .pw-kpi span { display: block; font-size: 0.6rem; color: var(--text-3); letter-spacing: 0.02em; line-height: 1.3; }
  .pw-kpi b { display: block; margin-top: 0.2rem; font-family: var(--font-display); font-weight: 700; font-size: 1.35rem; background: linear-gradient(180deg,#fff,#b9c6e0); -webkit-background-clip: text; background-clip: text; color: transparent; }
  .pw-kpi b i { font-style: normal; }
  .pw-kpi em { display: block; margin-top: 0.15rem; font-style: normal; font-size: 0.58rem; color: var(--text-3); min-height: 1em; }
  .pw-kpi em.up { color: #35e0a8; }

  .pw-optimize { width: 100%; justify-content: center; font-size: 0.95rem; }
  .pw-optimize:disabled { opacity: 0.75; cursor: default; transform: none !important; }
  .pw-optimize.is-done { background: linear-gradient(120deg, #1d8f66, #35e0a8); box-shadow: 0 10px 30px rgba(53, 224, 168, 0.35); }

  .pw-feedbox { border: 1px solid var(--border); border-radius: 14px; padding: 0.9rem 1rem; background: rgba(255,255,255,0.014); flex: 1; min-height: 0; }
  .pw-feedbox h4 { font-family: var(--font-mono); font-size: 0.64rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--text-3); margin-bottom: 0.7rem; display: flex; justify-content: space-between; align-items: center; }
  .pw-feed { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .pw-feed li {
    display: flex; align-items: flex-start; gap: 0.6rem;
    font-size: 0.75rem; line-height: 1.5; color: var(--text-2);
    padding: 0.5rem 0.6rem; border: 1px solid rgba(255,255,255,0.05); border-radius: 10px; background: rgba(255,255,255,0.012);
    opacity: 0; transform: translateY(-6px);
    animation: pw-feed-in 0.45s var(--ease-out) forwards;
  }
  @keyframes pw-feed-in { to { opacity: 1; transform: none; } }
  .pw-feed .ic { flex: 0 0 auto; width: 20px; height: 20px; display: grid; place-items: center; border-radius: 6px; font-size: 0.62rem; }
  .pw-feed .ic--ok { color: #79e2a0; background: rgba(121,226,160,0.1); }
  .pw-feed .ic--alerta { color: #e9c268; background: rgba(233,194,104,0.1); }
  .pw-feed .ic--info { color: var(--cyan-300); background: rgba(0,168,255,0.1); }
  .pw-feed .ic--ia { color: var(--gold-light); background: rgba(201,162,75,0.12); }

  @media (max-width: 900px) {
    .pw-grid { grid-template-columns: 1fr; }
    .pw-map { max-height: 46vh; }
  }
</style>

<script>
  import { registerDemo, mkScheduler, animateCount, prefersReduced, replay } from '../../scripts/demo-utils.js';

  const FEED = [
    { ic: 'info', t: 'Veículo 27 saiu do CD Central — 34 paradas na Zona Sul' },
    { ic: 'ok', t: 'Pedido #8.412 entregue no RJ — 22 min adiantado' },
    { ic: 'alerta', t: 'Chuva forte na Marginal — SP-011 com +18 min previstos' },
    { ic: 'ia', t: 'IA realocou a janela da Doca 4 (ociosa das 14h às 16h)' },
    { ic: 'ok', t: 'Rota BH concluída — 100% das entregas no prazo' },
    { ic: 'info', t: 'Veículo 41 abasteceu — consumo 8% abaixo da média' },
    { ic: 'alerta', t: 'Doca 2 com fila — 3 veículos aguardando' },
    { ic: 'ok', t: 'Pedido #8.437 entregue em POA — cliente avaliou 5★' },
    { ic: 'ia', t: 'IA antecipou manutenção do veículo 09 (vibração fora do padrão)' },
    { ic: 'info', t: '148 veículos ativos — telemetria 100% online' },
  ];
  const KPIS = {
    antes: { prazo: 89, custo: 100, ocupacao: 71 },
    depois: { prazo: 96, custo: 87, ocupacao: 83 },
  };
  const HUBS = {
    sp: { nome: 'CD Central · São Paulo', ent: '1.284', vei: '62', ocu: '84%', pon: '94%', nota: 'Hub principal. A IA sugere antecipar a janela da Doca 4, ociosa entre 14h e 16h.' },
    rj: { nome: 'Hub Rio de Janeiro', ent: '312', vei: '18', ocu: '71%', pon: '91%', nota: 'Chuva forte na região — rota SP-011 com desvio sugerido pela IA (−38 min).' },
    bh: { nome: 'Hub Belo Horizonte', ent: '246', vei: '14', ocu: '66%', pon: '97%', nota: 'Melhor pontualidade da malha. Rota 100% no prazo hoje.' },
    bsb: { nome: 'Hub Brasília', ent: '188', vei: '11', ocu: '58%', pon: '93%', nota: 'Capacidade ociosa — candidata a absorver o interior de GO (sugestão da IA).' },
    rec: { nome: 'Hub Recife', ent: '204', vei: '12', ocu: '77%', pon: '89%', nota: 'ETA médio caiu 22 min após a última otimização de rotas.' },
    cwb: { nome: 'Hub Curitiba', ent: '176', vei: '10', ocu: '62%', pon: '95%', nota: 'Fluxo estável. Doca 2 com fila pontual às 9h — janela realocada.' },
    poa: { nome: 'Hub Porto Alegre', ent: '142', vei: '9', ocu: '54%', pon: '92%', nota: 'Volume em alta de 8% na semana — monitorando capacidade.' },
  };

  registerDemo('processflow', {
    sched: null, feedIdx: 0,

    pushFeed(root, item) {
      const ul = root.querySelector('.pw-feed');
      const li = document.createElement('li');
      const ic = document.createElement('span');
      ic.className = `ic ic--${item.ic}`;
      ic.textContent = item.ic === 'ok' ? '✓' : item.ic === 'alerta' ? '!' : item.ic === 'ia' ? '✦' : '›';
      const tx = document.createElement('span');
      tx.textContent = item.t;
      li.append(ic, tx);
      ul.prepend(li);
      while (ul.children.length > 6) ul.lastElementChild.remove();
    },

    setKpis(root, vals, deltas) {
      Object.entries(vals).forEach(([k, v]) => {
        const el = root.querySelector(`[data-kpi="${k}"]`);
        if (el) animateCount(el, v, 0, '');
      });
      if (deltas) {
        Object.entries(deltas).forEach(([k, t]) => {
          const el = root.querySelector(`[data-kpid="${k}"]`);
          if (el) { el.textContent = t; el.classList.add('up'); }
        });
      }
    },

    showHub(root, key) {
      const h = HUBS[key];
      if (!h) return;
      root.querySelectorAll('.pw-hubg').forEach((g) => g.classList.toggle('is-sel', g.dataset.hub === key));
      const card = root.querySelector('.pw-hubcard');
      card.hidden = false;
      card.querySelector('.pw-hubcard__nome').textContent = h.nome;
      card.querySelector('.pw-hubcard__ent').textContent = h.ent;
      card.querySelector('.pw-hubcard__vei').textContent = h.vei;
      card.querySelector('.pw-hubcard__ocu').textContent = h.ocu;
      card.querySelector('.pw-hubcard__pon').textContent = h.pon;
      card.querySelector('.pw-hubcard__nota').textContent = h.nota;
    },
    hideHub(root) {
      root.querySelector('.pw-hubcard').hidden = true;
      root.querySelectorAll('.pw-hubg').forEach((g) => g.classList.remove('is-sel'));
    },

    onAction(action, el, root) {
      if (action === 'pw-hub') { this.showHub(root, el.dataset.hub); return; }
      if (action === 'pw-hub-close') { this.hideHub(root); return; }
      if (action !== 'pw-optimize' || el.disabled) return;
      const label = el.querySelector('.pw-optimize__label');
      el.disabled = true;
      label.textContent = 'Analisando 312 rotas…';
      this.sched.after(1400, () => {
        root.dataset.optimized = '1';
        // ETAs das entregas melhoram junto
        root.querySelectorAll('.pw-eta').forEach((td) => {
          td.textContent = td.dataset.etaDepois;
          td.classList.add('is-melhor');
        });
        this.setKpis(root, KPIS.depois, { prazo: '▲ +7pp agora', custo: '▼ −13% agora', ocupacao: '▲ +12pp agora' });
        label.textContent = 'Rotas otimizadas ✓';
        el.classList.add('is-done');
        this.pushFeed(root, { ic: 'ia', t: 'IA aplicou 47 ajustes de rota — −13% de custo e +7pp de pontualidade' });
        const toast = document.createElement('div');
        toast.className = 'pw-toast';
        toast.innerHTML = '<b>✦ Otimização aplicada:</b>&nbsp;47 rotas ajustadas · −13% custo · +7pp pontualidade';
        root.querySelector('.pw-toastzone').appendChild(toast);
        this.sched.after(6000, () => toast.remove());
      });
    },

    mount(root) {
      this.sched = mkScheduler();
      this.feedIdx = 0;
      // estado inicial
      delete root.dataset.optimized;
      const btn = root.querySelector('.pw-optimize');
      btn.disabled = false;
      btn.classList.remove('is-done');
      btn.querySelector('.pw-optimize__label').textContent = '✦ Otimizar rotas com IA';
      root.querySelectorAll('[data-kpid]').forEach((e) => { e.classList.remove('up'); });
      root.querySelector('[data-kpid="prazo"]').textContent = 'meta: 95%';
      root.querySelector('[data-kpid="custo"]').textContent = 'índice base 100';
      root.querySelector('[data-kpid="ocupacao"]').textContent = 'meta: 80%';
      root.querySelector('.pw-toastzone').textContent = '';
      this.hideHub(root);
      // reset das ETAs
      root.querySelectorAll('.pw-eta').forEach((td) => {
        td.textContent = td.dataset.etaAntes;
        td.classList.remove('is-melhor');
      });
      const ul = root.querySelector('.pw-feed');
      ul.textContent = '';
      // 3 eventos iniciais + fluxo contínuo
      FEED.slice(0, 3).forEach((f) => this.pushFeed(root, f));
      this.feedIdx = 3;
      if (!prefersReduced) {
        this.sched.every(3200, () => {
          this.pushFeed(root, FEED[this.feedIdx % FEED.length]);
          this.feedIdx++;
        });
      }
      this.setKpis(root, KPIS.antes);
      // SMIL: roda só com a demo aberta
      const svg = root.querySelector('.pw-map');
      if (prefersReduced) svg.pauseAnimations();
      else svg.unpauseAnimations();
      replay(root.querySelector('.pw-mapcol'));
    },

    unmount(root) {
      if (this.sched) this.sched.clear();
      const svg = root.querySelector('.pw-map');
      if (svg && svg.pauseAnimations) svg.pauseAnimations();
    },
  });
</script>
