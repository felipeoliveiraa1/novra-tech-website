---
// Atlas OS — app de gestão navegável: 4 módulos reais (visão geral,
// pedidos com filtro, clientes com busca, financeiro com fluxo de caixa).
const pedidos = [
  { id: '#4.812', cliente: 'Distribuidora Alfa', valor: 'R$ 12.480', status: 'faturado', label: 'faturado', data: '18/07' },
  { id: '#4.813', cliente: 'Grupo Horizonte', valor: 'R$ 8.940', status: 'em-rota', label: 'em rota', data: '18/07' },
  { id: '#4.814', cliente: 'Rede Vitale', valor: 'R$ 21.300', status: 'separacao', label: 'separação', data: '18/07' },
  { id: '#4.815', cliente: 'Casa & Cia', valor: 'R$ 4.120', status: 'aguardando', label: 'aguardando', data: '18/07' },
  { id: '#4.816', cliente: 'Bella Moda', valor: 'R$ 7.650', status: 'faturado', label: 'faturado', data: '17/07' },
  { id: '#4.817', cliente: 'TransLog Express', valor: 'R$ 15.980', status: 'em-rota', label: 'em rota', data: '17/07' },
  { id: '#4.818', cliente: 'Mercado União', valor: 'R$ 3.240', status: 'faturado', label: 'faturado', data: '17/07' },
  { id: '#4.819', cliente: 'Ótica Prisma', valor: 'R$ 1.890', status: 'separacao', label: 'separação', data: '16/07' },
  { id: '#4.820', cliente: 'AgroCampo BR', valor: 'R$ 28.700', status: 'faturado', label: 'faturado', data: '16/07' },
  { id: '#4.821', cliente: 'Farma Direta', valor: 'R$ 6.410', status: 'aguardando', label: 'aguardando', data: '16/07' },
];
const clientes = [
  { nome: 'Distribuidora Alfa', cidade: 'Campinas · SP', desde: '2023', ltv: 'R$ 148 mil', status: 'ativo' },
  { nome: 'Grupo Horizonte', cidade: 'São Paulo · SP', desde: '2022', ltv: 'R$ 231 mil', status: 'ativo' },
  { nome: 'Rede Vitale', cidade: 'Belo Horizonte · MG', desde: '2024', ltv: 'R$ 96 mil', status: 'ativo' },
  { nome: 'Casa & Cia', cidade: 'Curitiba · PR', desde: '2023', ltv: 'R$ 74 mil', status: 'inadimplente' },
  { nome: 'Bella Moda', cidade: 'Rio de Janeiro · RJ', desde: '2025', ltv: 'R$ 31 mil', status: 'ativo' },
  { nome: 'TransLog Express', cidade: 'Cajamar · SP', desde: '2022', ltv: 'R$ 187 mil', status: 'ativo' },
  { nome: 'AgroCampo BR', cidade: 'Rondonópolis · MT', desde: '2024', ltv: 'R$ 205 mil', status: 'ativo' },
  { nome: 'Farma Direta', cidade: 'Recife · PE', desde: '2025', ltv: 'R$ 42 mil', status: 'novo' },
];
const contas = [
  { venc: '22/07', desc: 'Frete — TransLog', valor: 'R$ 8.420', status: 'agendado' },
  { venc: '25/07', desc: 'Fornecedor — Máx Embalagens', valor: 'R$ 12.100', status: 'agendado' },
  { venc: '28/07', desc: 'Energia — unidade Campinas', valor: 'R$ 4.380', status: 'pendente' },
  { venc: '30/07', desc: 'Folha — colaboradores', valor: 'R$ 96.500', status: 'agendado' },
  { venc: '02/08', desc: 'Aluguel — CD Central', valor: 'R$ 22.000', status: 'pendente' },
];
---
<section class="demo at" id="demo-atlas" data-demo="atlas" data-view="visao" hidden>
  <aside class="at-side">
    <div class="at-side__brand">
      <img src="/brand/novra-icon-ui.png" alt="" width="26" height="28" />
      <span>Atlas<em>OS</em></span>
    </div>
    <nav class="at-nav">
      <button data-action="at-nav" data-view="visao" class="is-on" type="button"><i>▦</i> Visão geral</button>
      <button data-action="at-nav" data-view="pedidos" type="button"><i>▤</i> Pedidos</button>
      <button data-action="at-nav" data-view="clientes" type="button"><i>◉</i> Clientes</button>
      <button data-action="at-nav" data-view="financeiro" type="button"><i>◈</i> Financeiro</button>
    </nav>
    <div class="at-side__user">
      <span class="at-avatar">F</span>
      <div><b>Felipe O.</b><em>Diretor · Matriz</em></div>
    </div>
  </aside>

  <div class="at-main">
    <!-- ===== VISÃO GERAL ===== -->
    <div class="at-view at-view--visao">
      <header class="at-head"><h3>Visão geral</h3><span>sexta-feira, 18 de julho</span></header>
      <div class="at-kpis">
        <div class="at-kpi"><span>Faturamento do mês</span><b>R$ <i data-kpi="fat">0</i> mil</b><em class="up">▲ 12% vs jun</em></div>
        <div class="at-kpi"><span>Pedidos hoje</span><b><i data-kpi="ped">0</i></b><em class="up">▲ 5 desde ontem</em></div>
        <div class="at-kpi"><span>Ticket médio</span><b>R$ <i data-kpi="tik">0</i></b><em>estável</em></div>
        <div class="at-kpi"><span>Inadimplência</span><b><i data-kpi="ina">0</i>%</b><em class="up">▼ 0,8pp</em></div>
      </div>
      <div class="at-cols">
        <div class="at-panel">
          <h4>Fluxo do mês <span>entradas × saídas · R$ mil</span></h4>
          <svg class="at-chart" viewBox="0 0 560 170" preserveAspectRatio="none" aria-hidden="true">
            <defs>
              <linearGradient id="ga-in" x1="0" y1="0" x2="1" y2="0">
                <stop offset="0" stop-color="#2E6BFF"/><stop offset="1" stop-color="#00A8FF"/>
              </linearGradient>
            </defs>
            <path class="at-line at-line--in" fill="none" stroke="url(#ga-in)" stroke-width="2.5" stroke-linecap="round" d=""></path>
            <path class="at-line at-line--out" fill="none" stroke="rgba(201,162,75,0.85)" stroke-width="2" stroke-dasharray="5 5" stroke-linecap="round" d=""></path>
          </svg>
          <div class="at-legend"><span><i class="a"></i> entradas</span><span><i class="b"></i> saídas</span></div>
        </div>
        <div class="at-panel">
          <h4>Atalhos</h4>
          <div class="at-short">
            <button data-action="at-nav" data-view="pedidos" type="button">▤ Ver pedidos em aberto <em>4</em></button>
            <button data-action="at-nav" data-view="clientes" type="button">◉ Clientes inadimplentes <em>1</em></button>
            <button data-action="at-nav" data-view="financeiro" type="button">◈ Contas desta semana <em>2</em></button>
          </div>
          <div class="at-tip"><b>Atlas sugere:</b> o pedido #4.815 aguarda aprovação há 2 dias — o cliente costuma comprar 2× mais quando aprovado em 24h.</div>
        </div>
      </div>
    </div>

    <!-- ===== PEDIDOS ===== -->
    <div class="at-view at-view--pedidos" hidden>
      <header class="at-head"><h3>Pedidos</h3><span class="at-count">10 pedidos</span></header>
      <div class="at-filters">
        <button data-action="at-filter" data-status="todos" class="is-on" type="button">Todos</button>
        <button data-action="at-filter" data-status="faturado" type="button">Faturados</button>
        <button data-action="at-filter" data-status="em-rota" type="button">Em rota</button>
        <button data-action="at-filter" data-status="separacao" type="button">Separação</button>
        <button data-action="at-filter" data-status="aguardando" type="button">Aguardando</button>
      </div>
      <div class="at-panel at-panel--table">
        <table class="at-table">
          <thead><tr><th>Pedido</th><th>Cliente</th><th>Valor</th><th>Data</th><th>Status</th></tr></thead>
          <tbody>
            {pedidos.map((p) => (
              <tr data-status={p.status}>
                <td class="mono">{p.id}</td>
                <td class="name">{p.cliente}</td>
                <td>{p.valor}</td>
                <td class="mono dim">{p.data}</td>
                <td><span class={`at-badge at-badge--${p.status}`}>{p.label}</span></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- ===== CLIENTES ===== -->
    <div class="at-view at-view--clientes" hidden>
      <header class="at-head"><h3>Clientes</h3><span class="at-ccount">8 clientes</span></header>
      <input class="at-search" type="search" placeholder="Buscar por nome ou cidade… (experimente: vitale)" aria-label="Buscar cliente" />
      <div class="at-panel at-panel--table">
        <table class="at-table">
          <thead><tr><th>Cliente</th><th>Cidade</th><th>Desde</th><th>LTV</th><th>Status</th></tr></thead>
          <tbody>
            {clientes.map((c) => (
              <tr>
                <td class="name">{c.nome}</td>
                <td class="dim">{c.cidade}</td>
                <td class="mono dim">{c.desde}</td>
                <td>{c.ltv}</td>
                <td><span class={`at-badge at-badge--${c.status === 'ativo' ? 'faturado' : c.status === 'novo' ? 'em-rota' : 'aguardando'}`}>{c.status}</span></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- ===== FINANCEIRO ===== -->
    <div class="at-view at-view--financeiro" hidden>
      <header class="at-head"><h3>Financeiro</h3><span>posição de hoje</span></header>
      <div class="at-kpis at-kpis--3">
        <div class="at-kpi"><span>Saldo em caixa</span><b>R$ <i data-kpi="saldo">0</i> mil</b><em class="up">▲ saudável</em></div>
        <div class="at-kpi"><span>A receber (30d)</span><b>R$ <i data-kpi="receber">0</i> mil</b><em>12 títulos</em></div>
        <div class="at-kpi"><span>A pagar (30d)</span><b>R$ <i data-kpi="pagar">0</i> mil</b><em>5 contas</em></div>
      </div>
      <div class="at-panel at-panel--table">
        <h4>Próximas contas</h4>
        <table class="at-table">
          <thead><tr><th>Venc.</th><th>Descrição</th><th>Valor</th><th>Status</th></tr></thead>
          <tbody>
            {contas.map((c) => (
              <tr>
                <td class="mono dim">{c.venc}</td>
                <td class="name">{c.desc}</td>
                <td>{c.valor}</td>
                <td><span class={`at-badge at-badge--${c.status === 'agendado' ? 'faturado' : 'aguardando'}`}>{c.status}</span></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>

<style is:global>
  .at { display: grid; grid-template-columns: 200px 1fr; min-height: 100%; background: #0a0b10; }
  .at-side { display: flex; flex-direction: column; gap: 1rem; border-right: 1px solid var(--border); padding: 1.1rem 0.8rem; background: rgba(255,255,255,0.012); }
  .at-side__brand { display: flex; align-items: center; gap: 0.5rem; font-family: var(--font-display); font-weight: 600; padding: 0.2rem 0.4rem; }
  .at-side__brand em { font-style: normal; color: var(--cyan-400); }
  .at-nav { display: flex; flex-direction: column; gap: 0.25rem; }
  .at-nav button {
    display: flex; align-items: center; gap: 0.6rem;
    font: inherit; font-size: 0.84rem; color: var(--text-2); text-align: left; cursor: pointer;
    padding: 0.6rem 0.7rem; border-radius: 10px; border: 1px solid transparent; background: none;
    transition: background 0.25s, color 0.25s, border-color 0.25s;
  }
  .at-nav button i { font-style: normal; opacity: 0.85; }
  .at-nav button:hover { background: var(--surface-hover); color: var(--text-1); }
  .at-nav button.is-on { background: rgba(46, 107, 255, 0.14); color: var(--text-1); border-color: rgba(46, 107, 255, 0.3); }
  .at-side__user { margin-top: auto; display: flex; align-items: center; gap: 0.6rem; padding: 0.4rem; }
  .at-avatar { display: grid; place-items: center; width: 32px; height: 32px; border-radius: 50%; background: var(--grad-brand); color: #fff; font-weight: 600; font-size: 0.8rem; }
  .at-side__user b { display: block; font-size: 0.76rem; }
  .at-side__user em { display: block; font-style: normal; font-size: 0.6rem; color: var(--text-3); }

  .at-main { padding: 1.2rem clamp(1rem, 2.4vw, 1.8rem) 2rem; min-width: 0; }
  .at-head { display: flex; align-items: baseline; justify-content: space-between; gap: 0.8rem; margin-bottom: 0.9rem; }
  .at-head h3 { font-family: var(--font-display); font-weight: 600; font-size: 1.15rem; }
  .at-head span { font-size: 0.72rem; color: var(--text-3); }

  .at-view.play .at-kpi, .at-view.play .at-panel { animation: at-in 0.5s var(--ease-out) both; }
  .at-view.play > *:nth-child(2) { animation-delay: 0.05s; }
  .at-view.play > *:nth-child(3) { animation-delay: 0.12s; }
  @keyframes at-in { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: none; } }

  .at-kpis { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.7rem; margin-bottom: 0.9rem; }
  .at-kpis--3 { grid-template-columns: repeat(3, 1fr); }
  .at-kpi { border: 1px solid var(--border); border-radius: 12px; padding: 0.75rem 0.9rem; background: rgba(255,255,255,0.016); min-width: 0; }
  .at-kpi span { display: block; font-size: 0.64rem; color: var(--text-3); letter-spacing: 0.03em; }
  .at-kpi b { display: block; margin-top: 0.15rem; font-family: var(--font-display); font-weight: 700; font-size: 1.25rem; background: linear-gradient(180deg,#fff,#b9c6e0); -webkit-background-clip: text; background-clip: text; color: transparent; white-space: nowrap; }
  .at-kpi b i { font-style: normal; }
  .at-kpi em { display: block; margin-top: 0.1rem; font-style: normal; font-size: 0.64rem; color: var(--text-3); }
  .at-kpi em.up { color: #79e2a0; }

  .at-cols { display: grid; grid-template-columns: 1.4fr 1fr; gap: 0.9rem; }
  .at-cols > * { min-width: 0; }
  .at-panel { border: 1px solid var(--border); border-radius: 14px; padding: 0.9rem 1rem 1rem; background: rgba(255,255,255,0.014); min-width: 0; }
  .at-panel h4 { font-family: var(--font-mono); font-size: 0.64rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--text-3); margin-bottom: 0.7rem; }
  .at-panel h4 span { text-transform: none; letter-spacing: 0.02em; margin-left: 0.5rem; }
  .at-chart { width: 100%; height: 150px; display: block; }
  .at-line--in { stroke-dasharray: 1200; stroke-dashoffset: 1200; }
  .play .at-line--in { animation: at-draw 1.2s var(--ease-out) 0.15s forwards; }
  .at-line--out { opacity: 0; }
  .play .at-line--out { animation: at-fadein 0.6s ease 1s forwards; }
  @keyframes at-draw { to { stroke-dashoffset: 0; } }
  @keyframes at-fadein { to { opacity: 1; } }
  .at-legend { display: flex; gap: 1rem; margin-top: 0.4rem; font-size: 0.66rem; color: var(--text-3); }
  .at-legend i { display: inline-block; width: 14px; height: 3px; border-radius: 2px; margin-right: 0.35rem; vertical-align: middle; }
  .at-legend .a { background: var(--grad-brand); }
  .at-legend .b { background: rgba(201,162,75,0.85); }

  .at-short { display: flex; flex-direction: column; gap: 0.45rem; }
  .at-short button {
    display: flex; align-items: center; gap: 0.5rem;
    font: inherit; font-size: 0.78rem; color: var(--text-1); text-align: left; cursor: pointer;
    padding: 0.6rem 0.8rem; border: 1px solid var(--border); border-radius: 10px; background: var(--surface);
    transition: border-color 0.25s, background 0.25s, transform 0.25s var(--ease-out);
  }
  .at-short button:hover { border-color: var(--border-brand); background: rgba(46,107,255,0.07); transform: translateY(-1px); }
  .at-short button em { margin-left: auto; font-style: normal; font-family: var(--font-mono); font-size: 0.66rem; color: var(--cyan-400); }
  .at-tip { margin-top: 0.8rem; font-size: 0.74rem; line-height: 1.55; color: var(--text-2); border-left: 2px solid var(--gold); padding-left: 0.75rem; }
  .at-tip b { color: var(--gold-light); }

  .at-filters { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 0.8rem; }
  .at-filters button {
    font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.04em; color: var(--text-2); cursor: pointer;
    padding: 0.4rem 0.8rem; border: 1px solid var(--border); border-radius: 99px; background: var(--surface);
    transition: all 0.25s;
  }
  .at-filters button.is-on { background: linear-gradient(120deg, rgba(46,107,255,0.85), rgba(0,168,255,0.85)); color: #fff; border-color: transparent; }

  .at-search {
    width: 100%; font: inherit; font-size: 0.84rem; color: var(--text-1);
    background: var(--surface); border: 1px solid var(--border-strong); border-radius: 12px;
    padding: 0.65rem 0.95rem; outline: none; margin-bottom: 0.8rem;
  }
  .at-search:focus { border-color: var(--border-brand); }
  .at-search::placeholder { color: var(--text-3); }

  .at-panel--table { overflow-x: auto; }
  .at-table { width: 100%; border-collapse: collapse; font-size: 0.78rem; }
  .at-table th { text-align: left; font-family: var(--font-mono); font-size: 0.58rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-3); padding: 0.4rem 0.55rem; border-bottom: 1px solid var(--border); }
  .at-table td { padding: 0.55rem; border-bottom: 1px solid rgba(255,255,255,0.05); color: var(--text-2); white-space: nowrap; }
  .at-table .name { color: var(--text-1); font-weight: 500; }
  .at-table .mono { font-family: var(--font-mono); font-size: 0.7rem; }
  .at-table .dim { color: var(--text-3); }
  .at-badge { font-family: var(--font-mono); font-size: 0.58rem; letter-spacing: 0.04em; padding: 0.22em 0.6em; border-radius: 99px; }
  .at-badge--faturado { color: #79e2a0; border: 1px solid rgba(121,226,160,0.35); background: rgba(121,226,160,0.08); }
  .at-badge--em-rota { color: var(--cyan-300); border: 1px solid rgba(0,168,255,0.4); background: rgba(0,168,255,0.08); }
  .at-badge--separacao { color: #c9cfdd; border: 1px solid var(--border-strong); background: var(--surface); }
  .at-badge--aguardando { color: #e9c268; border: 1px solid rgba(233,194,104,0.35); background: rgba(233,194,104,0.08); }

  @media (max-width: 860px) {
    .at { grid-template-columns: 1fr; }
    .at-side { flex-direction: row; align-items: center; border-right: 0; border-bottom: 1px solid var(--border); padding: 0.7rem 0.9rem; overflow-x: auto; }
    .at-nav { flex-direction: row; }
    .at-nav button { white-space: nowrap; padding: 0.45rem 0.6rem; }
    .at-side__brand span { display: none; }
    .at-side__user { display: none; }
    .at-kpis, .at-kpis--3 { grid-template-columns: repeat(2, 1fr); }
    .at-cols { grid-template-columns: 1fr; }
  }
</style>

<script>
  import { registerDemo, mkScheduler, animateCount, linePath, replay } from '../../scripts/demo-utils.js';

  const CAIXA = {
    entradas: [420, 455, 438, 510, 532, 548],
    saidas: [365, 371, 380, 392, 405, 398],
  };
  const KPIS = {
    visao: { fat: [532, 0, ''], ped: [38, 0, ''], tik: [358, 0, ''], ina: [2.4, 1, ''] },
    financeiro: { saldo: [412, 0, ''], receber: [386, 0, ''], pagar: [143, 0, ''] },
  };

  registerDemo('atlas', {
    ac: null, sched: null,

    go(root, view) {
      root.dataset.view = view;
      root.querySelectorAll('.at-nav button').forEach((b) => b.classList.toggle('is-on', b.dataset.view === view));
      root.querySelectorAll('.at-view').forEach((v) => { v.hidden = !v.classList.contains('at-view--' + view); });
      const active = root.querySelector('.at-view--' + view);
      replay(active);
      const kpis = KPIS[view];
      if (kpis) {
        Object.entries(kpis).forEach(([k, [v, d, s]]) => {
          const el = root.querySelector(`[data-kpi="${k}"]`);
          if (el) animateCount(el, v, d, s);
        });
      }
      if (view === 'visao') this.paintChart(root);
    },

    paintChart(root) {
      root.querySelector('.at-line--in').setAttribute('d', linePath(CAIXA.entradas, 560, 170, 10));
      root.querySelector('.at-line--out').setAttribute('d', linePath(CAIXA.saidas, 560, 170, 10));
    },

    onAction(action, el, root) {
      if (action === 'at-nav') this.go(root, el.dataset.view);
      if (action === 'at-filter') {
        const st = el.dataset.status;
        root.querySelectorAll('.at-filters button').forEach((b) => b.classList.toggle('is-on', b === el));
        let n = 0;
        root.querySelectorAll('.at-view--pedidos tbody tr').forEach((tr) => {
          const show = st === 'todos' || tr.dataset.status === st;
          tr.hidden = !show;
          if (show) n++;
        });
        root.querySelector('.at-count').textContent = `${n} pedido${n === 1 ? '' : 's'}`;
      }
    },

    mount(root) {
      this.ac = new AbortController();
      this.sched = mkScheduler();
      // reset de filtros/contadores (podem ter ficado de uma visita anterior)
      root.querySelectorAll('.at-filters button').forEach((b) => b.classList.toggle('is-on', b.dataset.status === 'todos'));
      root.querySelectorAll('.at-view--pedidos tbody tr, .at-view--clientes tbody tr').forEach((tr) => { tr.hidden = false; });
      root.querySelector('.at-count').textContent = '10 pedidos';
      root.querySelector('.at-ccount').textContent = '8 clientes';
      this.go(root, 'visao');
      // busca de clientes
      const search = root.querySelector('.at-search');
      search.value = '';
      search.addEventListener('input', () => {
        const q = search.value.trim().toLowerCase();
        let n = 0;
        root.querySelectorAll('.at-view--clientes tbody tr').forEach((tr) => {
          const show = !q || tr.textContent.toLowerCase().includes(q);
          tr.hidden = !show;
          if (show) n++;
        });
        root.querySelector('.at-ccount').textContent = `${n} cliente${n === 1 ? '' : 's'}`;
      }, { signal: this.ac.signal });
    },

    unmount(root) {
      if (this.ac) this.ac.abort();
      if (this.sched) this.sched.clear();
      // reseta filtros/busca p/ próxima abertura
      root.querySelectorAll('.at-view--pedidos tbody tr, .at-view--clientes tbody tr').forEach((tr) => { tr.hidden = false; });
    },
  });
</script>
