---
const segments = [
  'Fintech', 'Healthtech', 'E-commerce & Varejo', 'Logística & Supply Chain',
  'Indústria 4.0', 'SaaS B2B', 'Energia', 'Agronegócio', 'Seguros', 'Educação',
];
---
<section class="trust section-sm" aria-label="Setores atendidos">
  <div class="container">
    <p class="trust__label" data-reveal>
      <!-- EDITE: troque por logos de clientes reais quando disponíveis -->
      Engenharia de alto nível para líderes em
    </p>
  </div>
  <div class="marquee trust__marquee" style="--marquee-dur: 46s; --marquee-gap: 3.5rem">
    <div class="marquee__track">
      {segments.map((s) => (
        <span class="trust__item">{s}<i class="trust__sep"></i></span>
      ))}
    </div>
    <div class="marquee__track" aria-hidden="true">
      {segments.map((s) => (
        <span class="trust__item">{s}<i class="trust__sep"></i></span>
      ))}
    </div>
  </div>
</section>

<style>
  .trust { position: relative; z-index: 2; border-block: 1px solid var(--border); }
  .trust__label {
    text-align: center;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-3);
    margin-bottom: 1.8rem;
  }
  .trust__item {
    display: inline-flex; align-items: center; gap: 3.5rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.3rem, 1rem + 1.6vw, 2rem);
    letter-spacing: -0.02em;
    color: var(--text-1);
    opacity: 0.85;
    transition: opacity 0.4s var(--ease-out), color 0.4s var(--ease-out);
    white-space: nowrap;
  }
  .marquee:hover .trust__item { opacity: 0.5; }
  .trust__item:hover { opacity: 1; color: #fff; }
  .trust__sep {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--cyan-400); box-shadow: 0 0 12px rgba(0, 168, 255, 0.7);
    flex-shrink: 0;
  }
</style>
