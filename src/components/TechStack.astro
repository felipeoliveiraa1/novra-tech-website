---
import Icon from './Icon.astro';

const groups = [
  {
    icon: 'cloud',
    label: 'Cloud & Infraestrutura',
    items: ['AWS', 'Google Cloud', 'Azure', 'Kubernetes', 'Docker', 'Terraform'],
  },
  {
    icon: 'code',
    label: 'Linguagens & Engenharia',
    items: ['TypeScript', 'Python', 'Go', 'Java', 'Rust', 'Node.js'],
  },
  {
    icon: 'devices',
    label: 'Web & Mobile',
    items: ['React', 'Next.js', 'Astro', 'React Native', 'Flutter', 'PWA'],
  },
  {
    icon: 'data',
    label: 'Dados & Streaming',
    items: ['PostgreSQL', 'Kafka', 'Spark', 'Snowflake', 'Redis', 'dbt'],
  },
  {
    icon: 'ai',
    label: 'IA & Machine Learning',
    items: ['Claude', 'OpenAI', 'PyTorch', 'LangChain', 'Vector DBs', 'MLOps'],
  },
  {
    icon: 'security',
    label: 'Segurança & Observabilidade',
    items: ['Grafana', 'Datadog', 'Vault', 'SOC 2', 'OWASP', 'Sentry'],
  },
];
---
<section class="section tech" id="tecnologias">
  <span class="glow-orb tech__orb" aria-hidden="true"></span>
  <div class="container">
    <div class="section-head is-centered" data-reveal>
      <span class="eyebrow is-centered">Stack de nível enterprise</span>
      <h2 class="h2 balance">A tecnologia certa para <span class="text-gradient">cada desafio</span></h2>
      <p class="lead pretty">
        Não temos compromisso com ferramentas, e sim com resultados. Dominamos um
        ecossistema completo para escolher — e operar — a melhor solução para o seu contexto.
      </p>
    </div>

    <div class="tech__grid">
      {groups.map((g, i) => (
        <article class="tech__card card" data-reveal style={`--reveal-delay: ${(i % 3) * 90}ms`}>
          <div class="tech__head">
            <span class="tech__icon"><Icon name={g.icon} size={20} /></span>
            <h3 class="tech__label">{g.label}</h3>
          </div>
          <ul class="tech__items">
            {g.items.map((t) => <li class="tech__chip">{t}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .tech { position: relative; z-index: 2; overflow: hidden; }
  .tech__orb {
    bottom: -10%; left: 50%; transform: translateX(-50%);
    width: 60vw; height: 40vw; max-width: 820px; max-height: 560px;
    background: radial-gradient(circle, rgba(0, 168, 255, 0.12), transparent 64%);
  }
  .tech .section-head { margin-bottom: clamp(2.5rem, 1.5rem + 3vw, 4rem); }
  .tech__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.1rem;
  }
  .tech__card { padding: clamp(1.4rem, 1.1rem + 1vw, 1.8rem); }
  .tech__head { display: flex; align-items: center; gap: 0.8rem; margin-bottom: 1.2rem; }
  .tech__icon {
    display: grid; place-items: center; width: 40px; height: 40px; border-radius: 11px;
    background: rgba(46, 107, 255, 0.14); border: 1px solid var(--border-brand); color: var(--cyan-300);
  }
  .tech__label { font-size: 1.02rem; }
  .tech__items { display: flex; flex-wrap: wrap; gap: 0.55rem; }
  .tech__chip {
    font-family: var(--font-mono); font-size: 0.78rem; color: var(--text-2);
    padding: 0.4em 0.8em; border: 1px solid var(--border); border-radius: var(--r-pill);
    background: var(--surface-2);
    transition: color 0.3s var(--ease-out), border-color 0.3s var(--ease-out), background 0.3s var(--ease-out);
  }
  .tech__chip:hover { color: var(--text-1); border-color: var(--border-brand); background: rgba(46, 107, 255, 0.12); }

  @media (min-width: 640px) { .tech__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1000px) { .tech__grid { grid-template-columns: repeat(3, 1fr); } }
</style>
