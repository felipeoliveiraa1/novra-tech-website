---
import Icon from './Icon.astro';

const services = [
  {
    icon: 'ai',
    title: 'Inteligência Artificial',
    desc: 'Modelos, copilotos e agentes que aprendem com os seus dados — em produção e com governança. IA aplicada a resultados reais, não a hype.',
    tags: ['LLMs', 'Copilotos', 'MLOps'],
  },
  {
    icon: 'code',
    title: 'Desenvolvimento de Sistemas',
    desc: 'Sistemas digitais robustos, escaláveis e seguros — do discovery à operação. Plataformas sob medida que sustentam o crescimento sem perder performance.',
    tags: ['Full-stack', 'APIs', 'Microsserviços'],
  },
  {
    icon: 'spark',
    title: 'Automações',
    desc: 'Automatizamos processos críticos para reduzir custo, erro e retrabalho. Sua operação rodando com mais velocidade, previsibilidade e escala.',
    tags: ['RPA', 'Integrações', 'Workflows'],
  },
  {
    icon: 'cloud',
    title: 'Cloud & Infraestrutura',
    desc: 'Arquiteturas em nuvem resilientes e observáveis, com custo sob controle. Infraestrutura como código e entregas contínuas de ponta a ponta.',
    tags: ['AWS', 'Kubernetes', 'IaC'],
  },
  {
    icon: 'security',
    title: 'Segurança Digital',
    desc: 'Segurança por design em cada camada. Hardening, conformidade (LGPD, SOC 2, ISO 27001) e resposta a incidentes para proteger o que é crítico.',
    tags: ['LGPD', 'SOC 2', 'Pentest'],
  },
  {
    icon: 'data',
    title: 'Dashboards & Dados',
    desc: 'Da ingestão à decisão: plataformas de dados confiáveis e dashboards que transformam informação dispersa em inteligência acionável em tempo real.',
    tags: ['Data Lake', 'BI', 'Streaming'],
  },
];
---
<section class="section services" id="solucoes">
  <span class="glow-orb services__orb" aria-hidden="true"></span>
  <div class="container">
    <div class="services__head">
      <div class="section-head" data-reveal>
        <span class="eyebrow">Soluções</span>
        <span class="signature-line signature-line--sm head-sig" aria-hidden="true"></span>
        <h2 class="h2 balance">Tecnologia inteligente, de ponta a <span class="text-gradient">ponta.</span></h2>
      </div>
      <p class="lead pretty services__intro" data-reveal style="--reveal-delay: 120ms">
        Um único parceiro para toda a operação digital — da estratégia à execução.
        Profundidade técnica e disciplina de entrega para transformar complexidade em clareza.
      </p>
    </div>

    <div class="services__grid">
      {services.map((s, i) => (
        <article class="service card card-accent" data-reveal style={`--reveal-delay: ${(i % 4) * 80}ms`}>
          <i class="card-halo" aria-hidden="true"></i>
          <span class="service__index">{String(i + 1).padStart(2, '0')}</span>
          <span class="service__icon"><Icon name={s.icon} size={26} /></span>
          <h3 class="service__title">{s.title}</h3>
          <p class="service__desc">{s.desc}</p>
          <ul class="service__tags">
            {s.tags.map((t) => <li>{t}</li>)}
          </ul>
          <span class="service__arrow"><Icon name="arrow-up-right" size={18} /></span>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .services { position: relative; z-index: 2; overflow: hidden; }
  .services__orb {
    top: -6%; left: 30%;
    width: 46vw; height: 46vw; max-width: 680px; max-height: 680px;
    background: radial-gradient(circle, rgba(46, 107, 255, 0.14), transparent 66%);
  }
  .services__head {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.4rem;
    align-items: end;
    margin-bottom: clamp(2.5rem, 1.5rem + 3vw, 4rem);
  }
  .services__intro { max-width: 480px; }

  .services__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.3rem;
  }
  .service {
    padding: clamp(1.6rem, 1.2rem + 1.2vw, 2.2rem);
    display: flex;
    flex-direction: column;
    min-height: 270px;
  }
  .service__index {
    position: absolute; top: 1.4rem; right: 1.5rem;
    font-family: var(--font-mono); font-size: 0.78rem; color: var(--text-3);
    letter-spacing: 0.05em;
  }
  .service__icon {
    display: grid; place-items: center;
    width: 54px; height: 54px;
    border-radius: 14px;
    background: linear-gradient(160deg, rgba(46, 107, 255, 0.22), rgba(0, 168, 255, 0.08));
    border: 1px solid var(--border-brand);
    color: var(--cyan-300);
    margin-bottom: 1.4rem;
    transition: transform 0.5s var(--ease-out), box-shadow 0.5s var(--ease-out);
  }
  .service:hover .service__icon { transform: translateY(-3px); box-shadow: var(--glow-cyan); }
  .service__title { font-size: 1.18rem; line-height: 1.2; margin-bottom: 0.7rem; }
  .service__desc { font-size: 0.95rem; color: var(--text-2); line-height: 1.6; }
  .service__tags { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: auto; padding-top: 1.3rem; }
  .service__tags li {
    font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.02em;
    color: var(--text-3);
    padding: 0.3em 0.65em;
    border: 1px solid var(--border); border-radius: var(--r-pill);
    background: var(--surface);
  }
  .service__arrow {
    position: absolute; bottom: 1.5rem; right: 1.5rem;
    color: var(--text-3);
    opacity: 0; transform: translate(-4px, 4px);
    transition: opacity 0.5s var(--ease-out), transform 0.5s var(--ease-out), color 0.5s var(--ease-out);
  }
  .service:hover .service__arrow { opacity: 1; transform: none; color: var(--cyan-400); }

  @media (min-width: 640px) {
    .services__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 900px) {
    .services__head { grid-template-columns: 1.4fr 1fr; }
  }
  @media (min-width: 980px) {
    .services__grid { grid-template-columns: repeat(3, 1fr); }
  }
</style>
