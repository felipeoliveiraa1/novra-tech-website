---
import Icon from './Icon.astro';

// EDITE: substitua pelo depoimento e pelos resultados de um cliente real.
const results = [
  { value: '−63%', label: 'em custo de infraestrutura' },
  { value: '4×', label: 'mais rápido para entrar em produção' },
  { value: '99,99%', label: 'de disponibilidade' },
];
---
<section class="section-sm proof">
  <div class="container">
    <div class="proof__card" data-reveal>
      <div class="proof__media" aria-hidden="true">
        <img src="/img/proof-team.jpg" alt="" loading="lazy" decoding="async" width="1000" height="820" />
        <span class="proof__media-scrim"></span>
      </div>
      <div class="proof__content">
        <span class="proof__glow" aria-hidden="true"></span>
        <span class="proof__quote-icon"><Icon name="quote" size={36} /></span>

        <blockquote class="proof__quote">
          “A NOVRA não entregou apenas software — reestruturou a forma como operamos.
          Em poucos meses, transformaram um sistema legado em uma plataforma que
          escala com o nosso crescimento.”
        </blockquote>

        <figcaption class="proof__author">
          <span class="proof__avatar" aria-hidden="true">A</span>
          <span>
            <strong>Diretoria de Tecnologia</strong>
            <small>Cliente enterprise · setor financeiro</small>
          </span>
        </figcaption>

        <div class="proof__results">
          {results.map((r) => (
            <div class="proof__result">
              <span class="proof__result-value">{r.value}</span>
              <span class="proof__result-label">{r.label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .proof { position: relative; z-index: 2; }
  .proof__card {
    position: relative;
    max-width: 1080px;
    margin-inline: auto;
    border-radius: var(--r-xl);
    border: 1px solid var(--border-strong);
    background: linear-gradient(180deg, rgba(16, 22, 42, 0.8), rgba(8, 11, 20, 0.9));
    overflow: hidden;
    display: grid;
    grid-template-columns: 1fr;
  }
  .proof__card::before {
    content: ""; position: absolute; inset: 0; padding: 1px; border-radius: inherit;
    background: linear-gradient(135deg, rgba(46, 107, 255, 0.5), transparent 40%, transparent 60%, rgba(0, 168, 255, 0.4));
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    -webkit-mask-composite: xor; mask-composite: exclude;
    pointer-events: none; z-index: 3;
  }
  .proof__media { position: relative; min-height: 220px; overflow: hidden; }
  .proof__media img { width: 100%; height: 100%; object-fit: cover; }
  .proof__media-scrim {
    position: absolute; inset: 0;
    background: linear-gradient(180deg, rgba(8,11,20,0.2), rgba(8,11,20,0.85) 92%);
  }
  .proof__content {
    position: relative;
    padding: clamp(2rem, 1.5rem + 2.5vw, 3.4rem);
  }
  .proof__glow {
    position: absolute; top: -30%; right: -10%;
    width: 70%; height: 80%; border-radius: 50%;
    background: radial-gradient(circle, rgba(46, 107, 255, 0.22), transparent 65%);
    filter: blur(40px); pointer-events: none;
  }
  .proof__quote-icon { display: inline-flex; color: var(--cyan-400); opacity: 0.7; margin-bottom: 1rem; position: relative; }
  .proof__quote {
    position: relative;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.25rem, 1rem + 1.4vw, 1.85rem);
    line-height: 1.3;
    letter-spacing: -0.02em;
    color: var(--text-1);
    text-wrap: pretty;
  }
  .proof__author {
    display: inline-flex; align-items: center; gap: 0.9rem;
    margin-top: 1.8rem; text-align: left;
  }
  .proof__avatar {
    display: grid; place-items: center; width: 46px; height: 46px; border-radius: 50%;
    background: var(--grad-brand); color: #fff; font-family: var(--font-display); font-weight: 700;
    box-shadow: var(--glow-blue);
  }
  .proof__author strong { display: block; font-family: var(--font-display); color: var(--text-1); font-size: 0.95rem; }
  .proof__author small { color: var(--text-3); font-size: 0.84rem; }

  .proof__results {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem;
    margin-top: 2.6rem; padding-top: 2.2rem; border-top: 1px solid var(--border);
  }
  .proof__result-value {
    display: block;
    font-family: var(--font-display); font-weight: 700;
    font-size: clamp(1.6rem, 1.2rem + 2vw, 2.6rem);
    letter-spacing: -0.03em;
    background: var(--grad-gold);
    -webkit-background-clip: text; background-clip: text; color: transparent;
  }
  .proof__result-label { font-size: 0.82rem; color: var(--text-3); }

  @media (min-width: 820px) {
    .proof__card { grid-template-columns: 0.78fr 1fr; }
    .proof__media { min-height: 100%; }
  }
  @media (max-width: 560px) {
    .proof__results { grid-template-columns: 1fr; gap: 1.4rem; }
    .proof__media { aspect-ratio: 16 / 9; min-height: 0; }
  }
</style>
