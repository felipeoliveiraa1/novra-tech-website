---
import Icon from './Icon.astro';

// EDITE: troque pelo seu e-mail e endpoint de formulário (Formspree, etc.).
const EMAIL = 'contato@novratech.com.br';
const FORM_ENDPOINT = 'https://formspree.io/f/SEU_ID_AQUI';
---
<section class="section cta" id="contato">
  <span class="glow-orb cta__orb" aria-hidden="true"></span>
  <div class="container cta__inner">
    <div class="cta__intro">
      <span class="eyebrow" data-reveal>Contato</span>
      <span class="signature-line signature-line--sm head-sig" data-reveal aria-hidden="true"></span>
      <h2 class="h2 balance" data-reveal style="--reveal-delay: 80ms">
        Pronto para construir a próxima camada da sua
        <span class="text-gradient">operação digital?</span>
      </h2>
      <p class="lead pretty" data-reveal style="--reveal-delay: 160ms">
        Conte o seu desafio. Em até 1 dia útil, um especialista da NOVRA retorna
        com um diagnóstico inicial e os próximos passos — sem compromisso.
      </p>

      <ul class="cta__benefits" data-reveal style="--reveal-delay: 240ms">
        <li><Icon name="check" size={18} /> Diagnóstico inicial gratuito</li>
        <li><Icon name="check" size={18} /> Resposta de um especialista sênior</li>
        <li><Icon name="check" size={18} /> Confidencialidade garantida (NDA sob demanda)</li>
      </ul>

      <div class="cta__direct" data-reveal style="--reveal-delay: 320ms">
        <span class="cta__direct-label">Prefere falar direto?</span>
        <a href={`mailto:${EMAIL}`} class="cta__mail" data-magnetic>
          <Icon name="mail" size={18} /> {EMAIL}
        </a>
      </div>
    </div>

    <form class="cta__form card" id="contact-form" action={FORM_ENDPOINT} method="POST" novalidate data-reveal style="--reveal-delay: 160ms">
      <div class="cta__field">
        <label for="cf-name">Nome</label>
        <input id="cf-name" name="nome" type="text" autocomplete="name" placeholder="Seu nome" required />
      </div>
      <div class="cta__row">
        <div class="cta__field">
          <label for="cf-email">E-mail corporativo</label>
          <input id="cf-email" name="email" type="email" autocomplete="email" placeholder="voce@empresa.com" required />
        </div>
        <div class="cta__field">
          <label for="cf-company">Empresa</label>
          <input id="cf-company" name="empresa" type="text" autocomplete="organization" placeholder="Nome da empresa" />
        </div>
      </div>
      <div class="cta__field">
        <label for="cf-type">Tipo de projeto</label>
        <div class="cta__select-wrap">
          <select id="cf-type" name="tipo">
            <option value="">Selecione uma opção</option>
            <option>Desenvolvimento de software</option>
            <option>Inteligência Artificial &amp; Automação</option>
            <option>Modernização / Cloud</option>
            <option>Dados &amp; Analytics</option>
            <option>Cibersegurança</option>
            <option>Consultoria estratégica</option>
            <option>Outro</option>
          </select>
          <Icon name="arrow-down" size={16} />
        </div>
      </div>
      <div class="cta__field">
        <label for="cf-message">Como podemos ajudar?</label>
        <textarea id="cf-message" name="mensagem" rows="4" placeholder="Descreva brevemente o seu desafio ou objetivo" required></textarea>
      </div>

      <button type="submit" class="btn btn-primary btn-lg btn-block" data-magnetic>
        <span class="cta__btn-label">Solicitar diagnóstico</span>
        <Icon name="arrow-right" />
      </button>
      <p class="cta__form-note" id="form-status" role="status" aria-live="polite">
        Ao enviar, você concorda em ser contatado pela NOVRA sobre o seu projeto.
      </p>
    </form>
  </div>
</section>

<style>
  .cta { position: relative; z-index: 2; overflow: hidden; }
  .cta__orb {
    bottom: -30%; right: 10%;
    width: 50vw; height: 50vw; max-width: 680px; max-height: 680px;
    background: radial-gradient(circle, rgba(0, 168, 255, 0.18), transparent 65%);
  }
  .cta__inner {
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2.5rem, 1.5rem + 4vw, 4rem);
    align-items: start;
  }
  .cta__intro .h2 { margin-top: 1.1rem; }
  .cta__intro .lead { margin-top: 1.3rem; max-width: 460px; }
  .cta__benefits { margin-top: 2rem; display: flex; flex-direction: column; gap: 0.85rem; }
  .cta__benefits li { display: flex; align-items: center; gap: 0.7em; color: var(--text-2); font-size: 0.96rem; }
  .cta__benefits :global(svg) { color: var(--cyan-400); flex-shrink: 0; }
  .cta__direct {
    margin-top: 2.4rem; padding-top: 1.6rem; border-top: 1px solid var(--border);
    display: flex; flex-direction: column; gap: 0.5rem;
  }
  .cta__direct-label { font-family: var(--font-mono); font-size: 0.76rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-3); }
  .cta__mail { display: inline-flex; align-items: center; gap: 0.5em; font-family: var(--font-display); font-weight: 600; color: var(--text-1); font-size: 1.05rem; width: fit-content; }
  .cta__mail :global(svg) { color: var(--cyan-400); }
  .cta__mail:hover { color: var(--cyan-300); }

  /* Form */
  .cta__form { padding: clamp(1.5rem, 1.2rem + 1.5vw, 2.2rem); display: flex; flex-direction: column; gap: 1.1rem; }
  .cta__form::before { display: none; }
  .cta__row { display: grid; grid-template-columns: 1fr; gap: 1.1rem; }
  .cta__field { display: flex; flex-direction: column; gap: 0.5rem; }
  .cta__field label { font-family: var(--font-mono); font-size: 0.74rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--text-3); }
  .cta__field input,
  .cta__field textarea,
  .cta__field select {
    width: 100%;
    padding: 0.85rem 1rem;
    background: var(--bg-0);
    border: 1px solid var(--border-strong);
    border-radius: var(--r-sm);
    color: var(--text-1);
    font-size: 0.96rem;
    transition: border-color 0.3s var(--ease-out), box-shadow 0.3s var(--ease-out), background 0.3s var(--ease-out);
  }
  .cta__field textarea { resize: vertical; min-height: 110px; }
  .cta__field input::placeholder, .cta__field textarea::placeholder { color: var(--text-3); }
  .cta__field input:focus,
  .cta__field textarea:focus,
  .cta__field select:focus {
    outline: none;
    border-color: var(--blue-500);
    box-shadow: 0 0 0 3px rgba(46, 107, 255, 0.18);
    background: var(--bg-1);
  }
  .cta__field input:user-invalid,
  .cta__field textarea:user-invalid { border-color: #f06565; }
  .cta__select-wrap { position: relative; }
  .cta__select-wrap :global(svg) { position: absolute; right: 1rem; top: 50%; transform: translateY(-50%); color: var(--text-3); pointer-events: none; }
  .cta__field select { appearance: none; cursor: pointer; padding-right: 2.4rem; }
  .cta__field select option { background: var(--bg-2); color: var(--text-1); }
  .cta__form button { margin-top: 0.4rem; }
  .cta__form-note { font-size: 0.78rem; color: var(--text-3); text-align: center; line-height: 1.5; }
  .cta__form-note.is-success { color: #4ade80; }
  .cta__form-note.is-error { color: #f06565; }

  @media (min-width: 560px) { .cta__row { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 980px) {
    .cta__inner { grid-template-columns: 1fr 1fr; gap: clamp(3rem, 5vw, 5rem); }
  }
</style>
