---
import Icon from './Icon.astro';

// Headline cinético (reveal por palavra). Acento em azul = tecnologia viva.
const words = [
  { t: 'Sistemas' }, { t: 'inteligentes' }, { t: 'para' },
  { t: 'a' }, { t: 'próxima', a: true }, { t: 'era.', a: true },
];
const caps = ['IA', 'Software', 'Automação', 'Cloud', 'Segurança', 'Dados'];
---
<section class="hero" id="topo">
  <div class="hero__bg" aria-hidden="true">
    <div class="hero__grid"></div>
    <div class="hero__glow"></div>
  </div>

  <div class="container hero__inner">
    <div class="hero__content">
      <div class="hero__eyebrow" data-reveal>
        <span class="chip">
          <span class="dot"></span>
          Tecnologia premium · IA · Cloud · Sistemas
        </span>
      </div>

      <h1 class="hero__title">
        {words.map((w, i) => (
          <span class={w.a ? 'hw hw--accent' : 'hw'} style={`--d:${i * 55 + 140}ms`}>{w.t}</span>
        ))}
      </h1>

      <span class="hero__sig signature-line" data-reveal style="--reveal-delay: 560ms" aria-hidden="true"></span>

      <p class="hero__lead lead pretty" data-reveal style="--reveal-delay: 640ms">
        Desenvolvemos soluções em tecnologia, IA, automação e sistemas digitais para
        empresas que buscam <strong>performance, segurança e escala.</strong>
      </p>

      <div class="hero__actions" data-reveal style="--reveal-delay: 740ms">
        <a href="#contato" class="btn btn-primary btn-lg" data-magnetic>
          Fale com um especialista
          <Icon name="arrow-right" />
        </a>
        <a href="#solucoes" class="btn btn-ghost btn-lg" data-magnetic>
          Conheça nossas soluções
        </a>
      </div>

      <ul class="hero__caps" data-reveal style="--reveal-delay: 840ms">
        {caps.map((c) => <li>{c}</li>)}
      </ul>
    </div>

    <div class="hero__visual" data-reveal style="--reveal-delay: 300ms" aria-hidden="true">
      <img class="hero__face" src="/img/hero-face.png" alt="" width="769" height="941" fetchpriority="high" />
      <span class="hero__face-fade"></span>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    z-index: 2;
    min-height: 100svh;
    display: flex;
    align-items: center;
    padding-top: clamp(6rem, 12vh, 8.5rem);
    padding-bottom: clamp(4rem, 8vh, 6rem);
    overflow: hidden;
  }
  /* Refined ambient — preto + grid sutil + um brilho azul suave (sem excesso) */
  .hero__bg { position: absolute; inset: 0; z-index: 0; pointer-events: none; }
  .hero__grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(241,242,245,0.028) 1px, transparent 1px),
      linear-gradient(90deg, rgba(241,242,245,0.028) 1px, transparent 1px);
    background-size: 72px 72px;
    -webkit-mask-image: radial-gradient(110% 90% at 20% 30%, #000 35%, transparent 78%);
    mask-image: radial-gradient(110% 90% at 20% 30%, #000 35%, transparent 78%);
  }
  .hero__glow {
    position: absolute; top: 38%; left: 62%; transform: translate(-50%, -50%);
    width: min(760px, 70vw); height: min(680px, 72vh);
    background: radial-gradient(closest-side, rgba(46,107,255,0.20), rgba(0,168,255,0.06) 55%, transparent 76%);
  }

  .hero__inner {
    position: relative; z-index: 2;
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2.5rem, 5vw, 4rem);
    align-items: center;
    width: 100%;
  }
  .hero__content { display: flex; flex-direction: column; align-items: flex-start; max-width: 640px; }

  /* Headline cinético */
  .hero__title {
    margin-top: 1.5rem;
    font-size: clamp(2.5rem, 1.3rem + 4.2vw, 4.6rem);
    line-height: 1.04;
    letter-spacing: -0.035em;
    font-weight: 600;
    color: var(--text-1);
    display: flex; flex-wrap: wrap; gap: 0 0.26em;
    max-width: 13ch;
  }
  .hw { display: inline-block; animation: word-rise 0.85s var(--ease-out) backwards; animation-delay: var(--d, 0ms); }
  .hw--accent {
    background: var(--grad-brand-soft);
    -webkit-background-clip: text; background-clip: text; color: transparent;
  }
  @keyframes word-rise {
    from { opacity: 0; transform: translateY(0.5em); filter: blur(10px); }
    to { opacity: 1; transform: none; filter: none; }
  }

  .hero__sig { margin: 1.7rem 0 0; width: 132px; }
  .hero__lead { margin-top: 1.5rem; max-width: 540px; color: var(--text-2); }
  .hero__lead strong { color: var(--text-1); font-weight: 600; }
  .hero__actions { display: flex; flex-wrap: wrap; gap: 0.9rem; margin-top: 2rem; }

  .hero__caps {
    display: flex; flex-wrap: wrap; gap: 0.6rem 0.5rem;
    margin-top: 2.2rem;
  }
  .hero__caps li {
    font-family: var(--font-mono); font-size: 0.76rem; letter-spacing: 0.04em;
    color: var(--text-2);
    padding: 0.4em 0.85em; border: 1px solid var(--border); border-radius: var(--r-pill);
    background: var(--surface);
  }

  /* Tech face */
  .hero__visual { position: relative; justify-self: center; width: 100%; max-width: 560px; }
  .hero__face {
    width: 100%; height: auto; display: block;
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 22%, #000 100%),
      linear-gradient(180deg, #000 70%, transparent);
    -webkit-mask-composite: source-in; mask-composite: intersect;
    mask-image: linear-gradient(90deg, transparent, #000 22%, #000 100%),
      linear-gradient(180deg, #000 70%, transparent);
    filter: contrast(1.05) brightness(1.02);
  }
  .hero__face-fade {
    position: absolute; inset: 0;
    background: linear-gradient(90deg, var(--bg-0) 2%, transparent 30%);
    pointer-events: none;
  }

  @media (min-width: 1000px) {
    .hero__inner { grid-template-columns: 1.05fr 0.95fr; }
    .hero__visual { justify-self: end; max-width: none; }
    .hero__face { max-height: 84vh; width: auto; margin-inline: auto; }
  }
  @media (max-width: 999px) {
    .hero__visual { order: -1; max-width: 360px; opacity: 0.9; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hw { animation: none; }
  }
</style>
