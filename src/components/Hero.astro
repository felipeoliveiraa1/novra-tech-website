---
import Icon from './Icon.astro';

const words = [
  { t: 'Sistemas' }, { t: 'inteligentes' }, { t: 'para' },
  { t: 'a' }, { t: 'próxima', a: true }, { t: 'era.', a: true },
];
const caps = ['IA', 'Software', 'Automação', 'Cloud', 'Segurança', 'Dados'];
---
<section class="hero" id="topo">
  <!-- Rosto tecnológico sangrando do canto direito, dissolvido no preto -->
  <div class="hero__face-layer" aria-hidden="true">
    <video class="hero__video" autoplay muted loop playsinline preload="auto" poster="/img/hero-poster.jpg">
      <source src="/hero.webm" type="video/webm" />
      <source src="/hero.mp4" type="video/mp4" />
    </video>
    <span class="hero__veil"></span>
  </div>

  <div class="container hero__inner">
    <div class="hero__content">
      <div class="hero__eyebrow" data-reveal>
        <span class="chip"><span class="dot"></span> Tecnologia premium · Sistemas inteligentes</span>
      </div>

      <h1 class="hero__title">
        {words.map((w, i) => (
          <span class={w.a ? 'hw hw--accent' : 'hw'} style={`--d:${i * 55 + 140}ms`}>{w.t}</span>
        ))}
      </h1>

      <span class="hero__sig signature-line" data-reveal style="--reveal-delay: 560ms" aria-hidden="true"></span>

      <p class="hero__lead lead pretty" data-reveal style="--reveal-delay: 640ms">
        Desenvolvemos soluções em tecnologia, IA, automação e sistemas digitais para
        empresas que buscam <strong>performance, segurança e escala.</strong>
      </p>

      <div class="hero__actions" data-reveal style="--reveal-delay: 740ms">
        <a href="#contato" class="btn btn-primary btn-lg" data-magnetic>
          Fale com um especialista
          <Icon name="arrow-right" />
        </a>
        <a href="#solucoes" class="btn btn-ghost btn-lg" data-magnetic>
          Conheça nossas soluções
        </a>
      </div>

      <ul class="hero__caps" data-reveal style="--reveal-delay: 840ms">
        {caps.map((c) => <li>{c}</li>)}
      </ul>
    </div>
  </div>

  <a class="hero__scroll" href="#solucoes" data-reveal style="--reveal-delay: 980ms" aria-label="Rolar">
    <span class="hero__scroll-line"><i></i></span>
  </a>
</section>

<style>
  .hero {
    position: relative;
    z-index: 2;
    min-height: 100svh;
    display: flex;
    align-items: center;
    padding-top: clamp(6rem, 12vh, 8.5rem);
    padding-bottom: clamp(5rem, 9vh, 7rem);
    overflow: hidden;
    background: var(--bg-0);
  }

  /* ---- Rosto no canto ---- */
  .hero__face-layer { position: absolute; inset: 0; z-index: 0; pointer-events: none; }
  /* vídeo de fundo (rosto à direita, preto à esquerda) */
  .hero__video {
    position: absolute; inset: 0; z-index: 0;
    width: 100%; height: 100%;
    object-fit: cover; object-position: right center;
    opacity: 0; transition: opacity 1.2s ease;
  }
  .hero__video.is-ready { opacity: 1; }
  /* véu: garante leitura do texto à esquerda + integra topo/base no preto */
  .hero__veil {
    position: absolute; inset: 0; z-index: 2;
    background:
      linear-gradient(90deg, var(--bg-0) 26%, rgba(10,10,12,0.55) 50%, transparent 78%),
      linear-gradient(180deg, var(--bg-0) 1%, transparent 16%, transparent 84%, var(--bg-0) 100%);
  }

  .hero__inner { position: relative; z-index: 2; width: 100%; }
  .hero__content { display: flex; flex-direction: column; align-items: flex-start; max-width: 600px; }

  .hero__title {
    margin-top: 1.4rem;
    font-size: clamp(2rem, 1.2rem + 3vw, 3.7rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    font-weight: 600;
    color: var(--text-1);
    display: flex; flex-wrap: wrap; gap: 0 0.24em;
    max-width: 14ch;
    text-shadow: 0 2px 40px rgba(0,0,0,0.6);
  }
  .hw { display: inline-block; animation: word-rise 0.85s var(--ease-out) backwards; animation-delay: var(--d, 0ms); }
  .hw--accent {
    background: var(--grad-brand-soft);
    -webkit-background-clip: text; background-clip: text; color: transparent;
  }
  @keyframes word-rise {
    from { opacity: 0; transform: translateY(0.5em); filter: blur(10px); }
    to { opacity: 1; transform: none; filter: none; }
  }

  .hero__sig { margin: 1.8rem 0 0; width: 128px; }
  .hero__lead {
    margin-top: 1.6rem; max-width: 480px; color: var(--text-2);
    text-shadow: 0 1px 18px rgba(0,0,0,0.6);
  }
  .hero__lead strong { color: var(--text-1); font-weight: 600; }
  .hero__actions { display: flex; flex-wrap: wrap; gap: 0.9rem; margin-top: 2.1rem; }
  .hero__caps { display: flex; flex-wrap: wrap; gap: 0.6rem 0.5rem; margin-top: 2.3rem; }
  .hero__caps li {
    font-family: var(--font-mono); font-size: 0.74rem; letter-spacing: 0.05em;
    color: var(--text-2);
    padding: 0.4em 0.85em; border: 1px solid var(--border); border-radius: var(--r-pill);
    background: rgba(255,255,255,0.015);
  }

  .hero__scroll { position: absolute; bottom: clamp(3.5rem, 6vh, 4.5rem); left: var(--gutter); z-index: 2; }
  .hero__scroll-line { display: block; width: 1px; height: 46px; background: var(--border-strong); position: relative; overflow: hidden; }
  .hero__scroll-line i { position: absolute; top: 0; left: 0; width: 100%; height: 45%; background: var(--blue-energy); animation: scroll-hint 2s var(--ease-in-out) infinite; }

  /* tablet/mobile: vídeo recua para o fundo, mais sutil (texto manda) */
  @media (max-width: 999px) {
    .hero__video { object-position: 72% center; opacity: 0.5; }
    .hero__video.is-ready { opacity: 0.5; }
    .hero__veil { background:
      linear-gradient(90deg, var(--bg-0) 36%, rgba(10,10,12,0.7) 62%, rgba(10,10,12,0.35) 100%),
      linear-gradient(180deg, var(--bg-0), transparent 22%, transparent 80%, var(--bg-0)); }
    .hero__content { max-width: 100%; }
    .hero__scroll { display: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hw { animation: none; }
    .hero__scroll-line i { animation: none; }
  }
</style>
