---
import Icon from './Icon.astro';
---
<section class="band" aria-label="Engenharia para escala global">
  <div class="band__media" aria-hidden="true">
    <img src="/img/band-earth.jpg" alt="" loading="lazy" decoding="async" width="1920" height="1000" data-band-parallax />
    <span class="band__overlay"></span>
    <span class="band__grid"></span>
  </div>
  <div class="container band__inner">
    <span class="eyebrow is-centered" data-reveal>Engenharia sem fronteiras</span>
    <h2 class="band__title h2 balance" data-reveal style="--reveal-delay: 100ms">
      Construímos sistemas que operam onde o
      <span class="text-gradient"> erro não é uma opção.</span>
    </h2>
    <p class="band__lead lead pretty" data-reveal style="--reveal-delay: 200ms">
      Da estratégia à operação contínua, a Novra entrega a confiabilidade,
      a segurança e a performance que sustentam negócios em escala.
    </p>
    <div class="band__cta" data-reveal style="--reveal-delay: 300ms">
      <a href="#contato" class="btn btn-primary btn-lg" data-magnetic>
        Falar com um especialista <Icon name="arrow-right" />
      </a>
    </div>
  </div>
</section>

<style>
  .band {
    position: relative;
    z-index: 2;
    display: grid;
    place-items: center;
    text-align: center;
    min-height: clamp(440px, 70vh, 640px);
    padding-block: clamp(4rem, 3rem + 6vw, 8rem);
    overflow: hidden;
    border-block: 1px solid var(--border);
  }
  .band__media { position: absolute; inset: 0; z-index: 0; }
  .band__media img {
    width: 100%; height: 128%;
    object-fit: cover;
    object-position: center 55%;
    will-change: transform;
    transform: translateY(-11%);
  }
  .band__overlay {
    position: absolute; inset: 0;
    background:
      radial-gradient(75% 80% at 50% 50%, rgba(5,7,14,0.12), rgba(5,7,14,0.62) 88%),
      linear-gradient(180deg, var(--bg-0), transparent 22%, transparent 74%, var(--bg-0));
  }
  .band__grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(120,180,255,0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(120,180,255,0.06) 1px, transparent 1px);
    background-size: 70px 70px;
    -webkit-mask-image: radial-gradient(70% 70% at 50% 50%, #000, transparent 75%);
    mask-image: radial-gradient(70% 70% at 50% 50%, #000, transparent 75%);
  }
  .band__inner {
    position: relative; z-index: 2;
    display: flex; flex-direction: column; align-items: center;
    max-width: 880px;
  }
  .band__title {
    margin-top: 1.2rem;
    font-size: clamp(2rem, 1.2rem + 3.6vw, 4rem);
    text-shadow: 0 2px 30px rgba(0, 0, 0, 0.55);
  }
  .band__lead {
    margin-top: 1.4rem; max-width: 620px;
    color: var(--text-1);
    text-shadow: 0 1px 18px rgba(0, 0, 0, 0.7);
  }
  .band__cta { margin-top: 2.2rem; }

  @media (prefers-reduced-motion: reduce) {
    .band__media img { transform: translateY(-12%) !important; }
  }
</style>
