---
import Base from '../layouts/Base.astro';

// Portfólio demonstrativo — 6 projetos-conceito cobrindo os 4 serviços core.
// Rota fora do menu: só quem tem o link vê (uso em reunião comercial).
const projects = [
  {
    slug: 'datatrust', num: '01', cat: 'Dados · Governança', setor: 'Varejo',
    name: 'DataTrust Hub',
    pitch: 'Dados confiáveis e LGPD em dia — sem trabalho manual.',
    mini: ['98,4% completude', '−80% risco de multa', 'LGPD 100%'],
    desafio: 'Cadastros de clientes duplicados, campos vazios e dados fora da LGPD geravam multas e decisões erradas em uma operação de varejo com milhões de registros.',
    solucao: 'Plataforma que audita os dados sozinha, corrige erros automaticamente, centraliza tudo num catálogo único e usa IA para apontar anomalias antes que virem prejuízo.',
    impacto: 'A empresa passa a confiar no próprio cadastro: menos multa, menos retrabalho e decisões tomadas em cima de números reais.',
    metrics: [
      { v: 98.4, d: 1, s: '%', label: 'completude dos dados' },
      { v: 80, d: 0, s: '%', label: 'menos risco de multa' },
      { v: 25, d: 0, s: '%', label: 'mais confiança p/ decidir' },
    ],
    stack: ['Python', 'Spark', 'Airflow', 'Machine Learning', 'AWS'],
  },
  {
    slug: 'processflow', num: '02', cat: 'Automações · Operação', setor: 'Logística',
    name: 'ProcessFlow AI',
    pitch: 'A operação inteira numa tela — e a IA sugerindo o melhor caminho.',
    mini: ['96% no prazo', '−30% custo', 'torre de controle'],
    desafio: 'Entregas atrasando, custo subindo e ninguém enxergava onde estava o gargalo: a operação rodava em planilhas e sistemas que não conversavam.',
    solucao: 'Torre de controle com mapa vivo da operação: rotas otimizadas por IA, alertas de atraso antes de acontecerem e tarefas repetitivas executadas por robôs.',
    impacto: 'O gestor vê tudo em tempo real e age antes do problema — a operação fica mais barata, mais rápida e previsível.',
    metrics: [
      { v: 30, d: 0, s: '%', label: 'menos custo operacional' },
      { v: 20, d: 0, s: '%', label: 'mais pontualidade' },
      { v: 96, d: 0, s: '%', label: 'entregas no prazo' },
    ],
    stack: ['RPA', 'IA de rotas', 'Integrações', 'Dashboards em tempo real'],
  },
  {
    slug: 'insightsphere', num: '03', cat: 'IA · Inteligência de Negócio', setor: 'Financeiro',
    name: 'InsightSphere',
    pitch: 'Pergunte em português. Receba a resposta em segundos.',
    mini: ['pergunta em texto livre', '−50% tempo de decisão', 'previsões por IA'],
    desafio: 'A diretoria esperava dias por relatórios: cada pergunta nova virava um chamado para o time de BI, e a decisão chegava atrasada.',
    solucao: 'Central de inteligência onde o executivo pergunta em linguagem natural ("qual região mais cresceu?") e a IA responde na hora, com gráfico e recomendação.',
    impacto: 'A resposta que levava uma semana passa a levar segundos — e a empresa enxerga oportunidades que antes passavam batido.',
    metrics: [
      { v: 50, d: 0, s: '%', label: 'menos tempo p/ decidir' },
      { v: 10, d: 0, s: '%', label: 'mais oportunidades vistas' },
      { v: 4, d: 0, s: 's', label: 'da pergunta à resposta' },
    ],
    stack: ['LLMs', 'NLP', 'BI self-service', 'Modelos preditivos'],
  },
  {
    slug: 'cloudbridge', num: '04', cat: 'Cloud · Modernização', setor: 'Indústria',
    name: 'CloudBridge',
    pitch: 'Do servidor antigo à nuvem — sem parar a fábrica.',
    mini: ['−40% custo de infra', 'zero downtime', '+30% velocidade'],
    desafio: 'Infraestrutura antiga, cara e no limite: sem espaço pra crescer, sem integração com nada novo e com risco real de parada.',
    solucao: 'Migração planejada de todos os sistemas e dados para a nuvem, por etapas e sem interromper a operação — com segurança e custo sob controle desde o dia 1.',
    impacto: 'A empresa troca um custo fixo alto por uma estrutura que cresce conforme a demanda — mais rápida, mais segura e 40% mais barata.',
    metrics: [
      { v: 40, d: 0, s: '%', label: 'menos custo de infra' },
      { v: 30, d: 0, s: '%', label: 'mais velocidade' },
      { v: 0, d: 0, s: '', label: 'minutos de parada na virada' },
    ],
    stack: ['Data Lakehouse', 'Snowflake', 'Kubernetes', 'Infra como código'],
  },
  {
    slug: 'atlas', num: '05', cat: 'Software sob medida', setor: 'Serviços',
    name: 'Atlas OS',
    pitch: 'O sistema que roda a empresa inteira — do jeito dela.',
    mini: ['1 sistema único', '−60% retrabalho', '99,9% no ar'],
    desafio: 'Sete planilhas, três sistemas que não conversavam e o processo inteiro dependendo da memória das pessoas. Crescer significava contratar mais gente pra apagar incêndio.',
    solucao: 'Plataforma única, desenhada em cima do processo real da empresa: vendas, operação, financeiro e relatórios no mesmo lugar, com permissões e trilha de auditoria.',
    impacto: 'A operação para de depender de heróis: qualquer pessoa entra, entende e executa. A empresa escala sem multiplicar o caos.',
    metrics: [
      { v: 60, d: 0, s: '%', label: 'menos retrabalho' },
      { v: 99.9, d: 1, s: '%', label: 'de disponibilidade' },
      { v: 1, d: 0, s: '', label: 'sistema no lugar de 10' },
    ],
    stack: ['React', 'Node.js', 'PostgreSQL', 'APIs & integrações'],
  },
  {
    slug: 'copiloto', num: '06', cat: 'IA · Atendimento', setor: 'Saúde',
    name: 'Copiloto NOVRA',
    pitch: 'Atende, agenda e resolve — 24h por dia, com a cara da sua empresa.',
    mini: ['78% resolvido sem humano', '24/7', 'CSAT 4,8'],
    desafio: 'Pacientes ligando fora do horário, fila no WhatsApp, agenda com buracos e a recepção afogada em tarefas repetitivas.',
    solucao: 'Assistente de IA no WhatsApp treinado com as regras da clínica: responde dúvidas, agenda e remarca consultas direto na agenda real, e passa pro humano quando precisa.',
    impacto: 'O paciente é atendido na hora, a qualquer hora — e a equipe fica livre pra cuidar de quem está na frente dela.',
    metrics: [
      { v: 78, d: 0, s: '%', label: 'resolvido sem humano' },
      { v: 24, d: 0, s: 'h', label: 'atendimento por dia' },
      { v: 4.8, d: 1, s: '', label: 'nota média (CSAT)' },
    ],
    stack: ['LLMs', 'WhatsApp API', 'Integração c/ agenda', 'CRM'],
  },
];
---
<Base
  title="NOVRA — Portfólio de projetos"
  description="Projetos-conceito da NOVRA em dados, automação, IA, cloud e software sob medida."
>
  <!-- topo próprio (sem âncoras da home) -->
  <header class="pf-top">
    <div class="container pf-top__inner">
      <a href="/" class="pf-top__brand" aria-label="NOVRA — página inicial">
        <img src="/brand/novra-logo-ui.png" alt="NOVRA" width="1041" height="308" />
      </a>
      <span class="chip"><span class="dot"></span> Portfólio · Projetos selecionados</span>
    </div>
  </header>

  <main id="main" class="pf">
    <section class="pf-hero">
      <span class="glow-orb pf-hero__orb" aria-hidden="true"></span>
      <div class="container">
        <div class="section-head" data-reveal>
          <span class="eyebrow">O que sabemos construir</span>
          <span class="signature-line signature-line--sm head-sig" aria-hidden="true"></span>
          <h1 class="h1 balance">Projetos que mostram o nosso <span class="text-gradient">potencial.</span></h1>
        </div>
        <p class="lead pretty pf-hero__lead" data-reveal style="--reveal-delay: 120ms">
          Seis projetos-conceito, um para cada frente em que atuamos.
          <strong>Toque em um card</strong> para abrir o projeto e ver a solução funcionando.
        </p>
      </div>
    </section>

    <section class="pf-gallery">
      <div class="container">
        <div class="pf-grid">
          {projects.map((p, i) => (
            <button class="pf-card card card-accent" data-open={p.slug} data-reveal style={`--reveal-delay: ${(i % 3) * 90}ms`} type="button">
              <i class="card-halo" aria-hidden="true"></i>
              <span class="pf-card__num">{p.num}</span>
              <span class="pf-card__cat">{p.cat}</span>
              <span class="pf-card__name">{p.name}</span>
              <span class="pf-card__pitch">{p.pitch}</span>
              <span class="pf-card__minis">
                {p.mini.map((m) => <em>{m}</em>)}
              </span>
              <span class="pf-card__go">Ver projeto <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17 17 7M8 7h9v9"/></svg></span>
            </button>
          ))}
        </div>
        <p class="pf-note" data-reveal>
          Projetos-conceito demonstrativos · métricas projetadas a partir de benchmarks de mercado.
        </p>
      </div>
    </section>
  </main>

  <!-- ===================== OVERLAY DE PROJETO ===================== -->
  <div class="pf-overlay" id="pf-overlay" hidden aria-modal="true" role="dialog">
    <div class="pf-overlay__backdrop" data-close></div>
    <div class="pf-sheet" data-lenis-prevent>
      <div class="pf-sheet__bar">
        <span class="pf-sheet__crumb">NOVRA · Portfólio</span>
        <div class="pf-sheet__nav">
          <button class="pf-navbtn" id="pf-prev" aria-label="Projeto anterior" type="button">←</button>
          <button class="pf-navbtn" id="pf-next" aria-label="Próximo projeto" type="button">→</button>
          <button class="pf-navbtn pf-navbtn--close" data-close aria-label="Fechar" type="button">✕</button>
        </div>
      </div>

      {projects.map((p) => (
        <article class="pf-detail" id={`pf-${p.slug}`} hidden>
          <header class="pf-detail__head">
            <span class="pf-detail__cat">{p.cat} · <b>{p.setor}</b></span>
            <h2 class="pf-detail__name">{p.name}</h2>
            <p class="pf-detail__pitch">{p.pitch}</p>
          </header>

          <div class="pf-screen" data-screen={p.slug}>
            <div class="pf-screen__bar" aria-hidden="true">
              <i></i><i></i><i></i>
              <span>{p.name} — demonstração</span>
            </div>
            <div class="pf-screen__body" id={`scr-${p.slug}`}></div>
          </div>

          <div class="pf-cols">
            <div class="pf-col"><h3>O desafio</h3><p>{p.desafio}</p></div>
            <div class="pf-col"><h3>A solução</h3><p>{p.solucao}</p></div>
            <div class="pf-col"><h3>O impacto</h3><p>{p.impacto}</p></div>
          </div>

          <div class="pf-metrics">
            {p.metrics.map((m) => (
              <div class="pf-metric">
                <span class="pf-metric__v" data-count={m.v} data-decimals={m.d} data-suffix={m.s}>0</span>
                <span class="pf-metric__l">{m.label}</span>
              </div>
            ))}
          </div>

          <div class="pf-stack">
            {p.stack.map((t) => <span>{t}</span>)}
          </div>
          <p class="pf-detail__note">Projeto-conceito demonstrativo · métricas projetadas.</p>
        </article>
      ))}
    </div>
  </div>

  <style is:global>
    /* is:global: as telas de demonstração são injetadas via JS (innerHTML) e
       não recebem o atributo de escopo do Astro — escopo manual via prefixos .pf-/.dz- */
    /* ---------- topo ---------- */
    .pf-top { position: relative; z-index: 5; padding-top: 1.6rem; }
    .pf-top__inner { display: flex; align-items: center; justify-content: space-between; gap: 1rem; }
    .pf-top__brand img { height: 38px; width: auto; display: block; }

    .pf { position: relative; z-index: 2; }

    /* ---------- hero ---------- */
    .pf-hero { position: relative; padding: clamp(3rem, 8vh, 5.5rem) 0 clamp(1.5rem, 4vh, 3rem); overflow: visible; }
    .pf-hero__orb { top: -30%; left: 8%; width: 44vw; height: 44vw; max-width: 620px; max-height: 620px;
      background: radial-gradient(circle, rgba(46, 107, 255, 0.16), transparent 66%); }
    .pf-hero__lead { max-width: 560px; margin-top: 1.2rem; }
    .pf-hero__lead strong { color: var(--text-1); }

    /* ---------- grid de cards ---------- */
    .pf-gallery { padding: 1rem 0 clamp(4rem, 9vh, 7rem); }
    .pf-grid { display: grid; grid-template-columns: 1fr; gap: 1.3rem; }
    @media (min-width: 640px) { .pf-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (min-width: 1020px) { .pf-grid { grid-template-columns: repeat(3, 1fr); } }

    .pf-card {
      text-align: left; cursor: pointer;
      display: flex; flex-direction: column; align-items: flex-start;
      padding: clamp(1.5rem, 1.2rem + 1vw, 2rem);
      min-height: 250px;
      color: inherit; font: inherit;
    }
    .pf-card__num {
      position: absolute; top: 1.3rem; right: 1.4rem;
      font-family: var(--font-mono); font-size: 0.78rem; color: var(--text-3); letter-spacing: 0.05em;
    }
    .pf-card__cat {
      font-family: var(--font-mono); font-size: 0.68rem; letter-spacing: 0.14em; text-transform: uppercase;
      color: var(--cyan-400); margin-bottom: 0.9rem;
    }
    .pf-card__name { font-family: var(--font-display); font-weight: 600; font-size: 1.35rem; letter-spacing: -0.01em; color: var(--text-1); }
    .pf-card__pitch { margin-top: 0.5rem; font-size: 0.93rem; line-height: 1.55; color: var(--text-2); }
    .pf-card__minis { display: flex; flex-wrap: wrap; gap: 0.45rem; margin-top: auto; padding-top: 1.2rem; }
    .pf-card__minis em {
      font-style: normal; font-family: var(--font-mono); font-size: 0.68rem; letter-spacing: 0.02em;
      color: var(--text-2); padding: 0.28em 0.6em;
      border: 1px solid var(--border); border-radius: var(--r-pill); background: var(--surface);
    }
    .pf-card__go {
      display: inline-flex; align-items: center; gap: 0.45rem;
      margin-top: 1.1rem; font-family: var(--font-display); font-weight: 600; font-size: 0.88rem;
      color: var(--cyan-400);
      opacity: 0.85; transition: opacity 0.4s var(--ease-out), gap 0.4s var(--ease-out);
    }
    .pf-card:hover .pf-card__go { opacity: 1; gap: 0.7rem; }

    .pf-note {
      margin-top: 2.2rem; text-align: center;
      font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.06em; color: var(--text-3);
    }

    /* ---------- overlay ---------- */
    .pf-overlay { position: fixed; inset: 0; z-index: 250; display: flex; align-items: flex-end; justify-content: center; }
    .pf-overlay[hidden] { display: none; } /* o display:flex acima venceria o [hidden] da UA */
    @media (min-width: 800px) { .pf-overlay { align-items: center; padding: 2.5rem; } }
    .pf-overlay__backdrop {
      position: absolute; inset: 0;
      background: rgba(5, 6, 10, 0.78); backdrop-filter: blur(10px);
      opacity: 0; transition: opacity 0.4s var(--ease-out);
    }
    .pf-overlay.is-open .pf-overlay__backdrop { opacity: 1; }
    .pf-sheet {
      position: relative; width: min(1060px, 100%);
      min-width: 0; /* flex min-width:auto deixaria o sheet mais largo que o viewport (SVGs largos) */
      max-height: min(92svh, 100%);
      overflow-y: auto; overscroll-behavior: contain;
      background: linear-gradient(180deg, #101118, #0b0c11);
      border: 1px solid var(--border-strong);
      border-radius: 22px 22px 0 0;
      padding: 0 clamp(1.2rem, 4vw, 3rem) 2.4rem;
      transform: translateY(40px); opacity: 0;
      transition: transform 0.5s var(--ease-out), opacity 0.5s var(--ease-out);
    }
    @media (min-width: 800px) { .pf-sheet { border-radius: 22px; } }
    .pf-overlay.is-open .pf-sheet { transform: none; opacity: 1; }

    .pf-sheet__bar {
      position: sticky; top: 0; z-index: 5;
      display: flex; align-items: center; justify-content: space-between;
      padding: 1.1rem 0 0.9rem; margin-bottom: 1.4rem;
      background: linear-gradient(180deg, #101118 74%, transparent);
    }
    .pf-sheet__crumb { font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--text-3); }
    .pf-sheet__nav { display: flex; gap: 0.5rem; }
    .pf-navbtn {
      width: 38px; height: 38px; border-radius: 10px;
      border: 1px solid var(--border-strong); background: var(--surface-2);
      color: var(--text-1); font-size: 0.95rem; cursor: pointer;
      transition: background 0.3s, border-color 0.3s, transform 0.3s var(--ease-out);
    }
    .pf-navbtn:hover { background: var(--surface-hover); border-color: var(--border-brand); transform: translateY(-1px); }

    .pf-detail__cat { font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--cyan-400); }
    .pf-detail__cat b { color: var(--gold-light); font-weight: 500; }
    .pf-detail__name { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.7rem, 1.2rem + 2vw, 2.5rem); letter-spacing: -0.02em; margin-top: 0.5rem; }
    .pf-detail__pitch { margin-top: 0.5rem; color: var(--text-2); font-size: 1.02rem; max-width: 60ch; }

    /* ---------- "tela" do produto ---------- */
    .pf-screen {
      margin-top: 1.6rem; border: 1px solid var(--border-strong); border-radius: 16px; overflow: hidden;
      background: #0a0b10; box-shadow: 0 30px 80px rgba(0, 0, 0, 0.5);
    }
    .pf-screen__bar {
      display: flex; align-items: center; gap: 7px;
      padding: 0.65rem 1rem; border-bottom: 1px solid var(--border);
      background: rgba(255, 255, 255, 0.02);
    }
    .pf-screen__bar i { width: 10px; height: 10px; border-radius: 50%; background: rgba(255,255,255,0.14); }
    .pf-screen__bar i:first-child { background: rgba(255, 99, 99, 0.55); }
    .pf-screen__bar i:nth-child(2) { background: rgba(255, 205, 100, 0.55); }
    .pf-screen__bar i:nth-child(3) { background: rgba(120, 220, 150, 0.55); }
    .pf-screen__bar span { margin-left: 0.6rem; font-family: var(--font-mono); font-size: 0.68rem; letter-spacing: 0.08em; color: var(--text-3); }
    .pf-screen__body { padding: clamp(1rem, 2.5vw, 1.6rem); min-height: 300px; }

    /* peças genéricas dos dashboards */
    .dz-kpis { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.8rem; }
    @media (max-width: 640px) { .dz-kpis { grid-template-columns: 1fr; } }
    .dz-kpi {
      border: 1px solid var(--border); border-radius: 12px; padding: 0.9rem 1rem;
      background: rgba(255, 255, 255, 0.018);
    }
    .dz-kpi b {
      display: block; font-family: var(--font-display); font-weight: 700; font-size: 1.55rem; letter-spacing: -0.02em;
      background: linear-gradient(180deg, #fff, #b9c6e0); -webkit-background-clip: text; background-clip: text; color: transparent;
    }
    .dz-kpi span { display: block; margin-top: 0.2rem; font-size: 0.72rem; color: var(--text-3); letter-spacing: 0.03em; }
    .dz-kpi .up { color: #79e2a0; } .dz-kpi .down { color: #79e2a0; }
    .dz-row { display: grid; gap: 0.9rem; margin-top: 0.9rem; grid-template-columns: 1.25fr 1fr; }
    .dz-row--side { grid-template-columns: 200px 1fr; }
    @media (max-width: 720px) { .dz-row, .dz-row--side { grid-template-columns: 1fr; } }
    /* itens de grid têm min-width:auto — SVGs com viewBox largo (460–520) forçariam
       min-content acima do viewport no phone; o par min-width:0 + max-width:100% resolve */
    .dz-row > *, .dz-kpis > * { min-width: 0; }
    .pf-screen__body svg { max-width: 100%; height: auto; }
    .dz-panel { border: 1px solid var(--border); border-radius: 12px; padding: 1rem; background: rgba(255,255,255,0.014); }
    .dz-panel h4 { font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--text-3); margin-bottom: 0.8rem; }
    .dz-list { display: flex; flex-direction: column; gap: 0.55rem; }
    .dz-list li { list-style: none; display: flex; align-items: center; gap: 0.6rem; font-size: 0.8rem; color: var(--text-2); }
    .dz-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--blue-energy); box-shadow: 0 0 8px rgba(0,168,255,0.7); animation: pulse-glow 2s ease-in-out infinite; }
    .dz-dot--gold { background: var(--gold); box-shadow: 0 0 8px rgba(201,162,75,0.7); }
    .dz-dot--ok { background: #79e2a0; box-shadow: 0 0 8px rgba(121,226,160,0.6); }
    .dz-bar { height: 8px; border-radius: 6px; background: rgba(255,255,255,0.07); overflow: hidden; flex: 1; }
    .dz-bar i { display: block; height: 100%; border-radius: 6px; background: var(--grad-brand); width: 0; }
    .play .dz-bar i { animation: dz-fill 1.2s var(--ease-out) forwards; }
    .dz-bar--gold i { background: var(--grad-gold); }
    @keyframes dz-fill { to { width: var(--w, 60%); } }
    .dz-chart path.line { fill: none; stroke: url(#pfgrad); stroke-width: 2.5; stroke-linecap: round;
      stroke-dasharray: 600; stroke-dashoffset: 600; }
    .play .dz-chart path.line { animation: dz-draw 1.6s var(--ease-out) 0.2s forwards; }
    .dz-chart path.area { fill: url(#pfarea); opacity: 0; }
    .play .dz-chart path.area { animation: dz-fade 0.8s ease 1.3s forwards; }
    @keyframes dz-draw { to { stroke-dashoffset: 0; } }
    @keyframes dz-fade { to { opacity: 1; } }
    .dz-donut .track { fill: none; stroke: rgba(255,255,255,0.08); stroke-width: 12; }
    .dz-donut .val { fill: none; stroke: url(#pfgrad); stroke-width: 12; stroke-linecap: round;
      stroke-dasharray: 289; stroke-dashoffset: 289; transform: rotate(-90deg); transform-origin: center; }
    .play .dz-donut .val { animation: dz-donut 1.4s var(--ease-out) 0.2s forwards; }
    @keyframes dz-donut { to { stroke-dashoffset: var(--off, 60); } }
    .dz-donut text { fill: #fff; font-family: var(--font-display); font-weight: 700; font-size: 22px; }
