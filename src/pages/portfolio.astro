---
import Base from '../layouts/Base.astro';
import DemoInsight from '../components/demos/DemoInsight.astro';
import DemoAgente from '../components/demos/DemoAgente.astro';
import DemoAtlas from '../components/demos/DemoAtlas.astro';
import DemoProcessflow from '../components/demos/DemoProcessflow.astro';

// Portfólio v2 — demos de produto imersivas. Rota fora do menu (uso comercial).
const projects = [
  {
    slug: 'insight', num: '01', cat: 'Dashboards · Inteligência de negócio',
    name: 'NOVRA Insight',
    pitch: 'BI com 3 áreas navegáveis: visão geral, vendas e clientes — e uma IA que responde em português.',
    tags: ['funil e ranking do time', 'clientes em risco (IA)', 'pergunte à IA'],
  },
  {
    slug: 'agente', num: '02', cat: 'Agentes de IA · Atendimento',
    name: 'Agente NOVRA',
    pitch: 'Um agente de IA no WhatsApp que agenda, cobra e resolve — converse com ele agora.',
    tags: ['converse de verdade', 'integrações ao vivo', '24/7'],
  },
  {
    slug: 'atlas', num: '03', cat: 'ERP · Gestão da empresa',
    name: 'Atlas ERP',
    pitch: 'O dia a dia da empresa em um clique: aprove compras, emita NF-e, reponha estoque e dê baixa em contas.',
    tags: ['emitir NF-e', 'aprovar compras', 'estoque + financeiro'],
  },
  {
    slug: 'processflow', num: '04', cat: 'Automações · Operação',
    name: 'ProcessFlow',
    pitch: 'Torre de controle logística: clique nos hubs, acompanhe entregas e otimize rotas com IA.',
    tags: ['hubs clicáveis', 'entregas ao vivo', 'otimizar com IA'],
  },
];
---
<Base
  title="NOVRA — Demos de produto"
  description="Quatro produtos interativos da NOVRA: BI com IA, agente de atendimento, app de gestão e torre de controle logística."
  noindex={true}
>
  <header class="pf-top">
    <div class="container pf-top__inner">
      <a href="/" class="pf-top__brand" aria-label="NOVRA — página inicial">
        <img src="/brand/novra-logo-ui.png" alt="NOVRA" width="1041" height="308" />
      </a>
      <span class="chip"><span class="dot"></span> Demos interativas</span>
    </div>
  </header>

  <main id="main" class="pf">
    <section class="pf-hero">
      <span class="glow-orb pf-hero__orb" aria-hidden="true"></span>
      <div class="container">
        <div class="section-head" data-reveal>
          <span class="eyebrow">Portfólio vivo</span>
          <span class="signature-line signature-line--sm head-sig" aria-hidden="true"></span>
          <h1 class="h1 balance">Quatro produtos. <span class="text-gradient">Entre e use.</span></h1>
        </div>
        <p class="lead pretty pf-hero__lead" data-reveal style="--reveal-delay: 120ms">
          Nada de slides: cada card abre um <strong>software funcionando</strong> —
          clique nos filtros, converse com o agente, navegue no app.
        </p>
      </div>
    </section>

    <section class="pf-gallery">
      <div class="container">
        <div class="pf-grid">
          {projects.map((p, i) => (
            <button class="pf-card card card-accent" data-open={p.slug} data-reveal style={`--reveal-delay: ${(i % 2) * 90}ms`} type="button">
              <i class="card-halo" aria-hidden="true"></i>
              <span class="pf-card__num">{p.num}</span>
              <span class="pf-card__cat">{p.cat}</span>
              <span class="pf-card__name">{p.name}</span>

              <span class={`pf-prev pf-prev--${p.slug}`} aria-hidden="true">
                {p.slug === 'insight' && (
                  <span class="pf-prev__frame">
                    <i class="pv-side"><b></b><b></b><b></b></i>
                    <i class="pv-main">
                      <em class="pv-kpi"></em><em class="pv-kpi"></em><em class="pv-kpi"></em>
                      <svg viewBox="0 0 200 46" preserveAspectRatio="none"><path d="M4 40 C 30 36, 50 30, 72 28 C 104 25, 126 16, 152 12 C 170 9, 186 6, 196 4" fill="none" stroke="url(#pvg)" stroke-width="2"/><defs><linearGradient id="pvg" x1="0" y1="0" x2="1" y2="0"><stop offset="0" stop-color="#2E6BFF"/><stop offset="1" stop-color="#00A8FF"/></linearGradient></defs></svg>
                    </i>
                  </span>
                )}
                {p.slug === 'agente' && (
                  <span class="pf-prev__frame pf-prev__frame--chat">
                    <i class="pv-bub pv-bub--in"></i>
                    <i class="pv-bub pv-bub--out"></i>
                    <i class="pv-bub pv-bub--in pv-bub--short"></i>
                    <i class="pv-dots"><b></b><b></b><b></b></i>
                  </span>
                )}
                {p.slug === 'atlas' && (
                  <span class="pf-prev__frame">
                    <i class="pv-side"><b></b><b></b><b></b><b></b></i>
                    <i class="pv-main">
                      <em class="pv-row"><b class="ok"></b></em>
                      <em class="pv-row"><b class="cy"></b></em>
                      <em class="pv-row"><b class="wa"></b></em>
                      <em class="pv-row"><b class="ok"></b></em>
                    </i>
                  </span>
                )}
                {p.slug === 'processflow' && (
                  <span class="pf-prev__frame pf-prev__frame--map">
                    <svg viewBox="0 0 220 92">
                      <path d="M92,8 L136,12 L172,26 L204,42 L188,64 L150,82 L108,88 L70,78 L38,58 L44,26 Z" fill="rgba(46,107,255,0.06)" stroke="rgba(120,158,255,0.3)" stroke-width="1"/>
                      <path d="M110,52 C 130,48 150,44 168,40" fill="none" stroke="rgba(120,170,255,0.55)" stroke-width="1.4" stroke-dasharray="4 4"/>
                      <path d="M110,52 C 100,62 90,70 82,76" fill="none" stroke="rgba(120,170,255,0.55)" stroke-width="1.4" stroke-dasharray="4 4"/>
                      <path d="M110,52 C 112,40 116,30 122,22" fill="none" stroke="rgba(201,162,75,0.7)" stroke-width="1.4" stroke-dasharray="4 4"/>
                      <circle cx="110" cy="52" r="4" fill="#10131c" stroke="#00A8FF" stroke-width="1.6"/>
                      <circle cx="168" cy="40" r="2.5" fill="#10131c" stroke="rgba(150,185,255,0.7)" stroke-width="1.2"/>
                      <circle cx="82" cy="76" r="2.5" fill="#10131c" stroke="rgba(150,185,255,0.7)" stroke-width="1.2"/>
                      <circle cx="122" cy="22" r="2.5" fill="#10131c" stroke="rgba(150,185,255,0.7)" stroke-width="1.2"/>
                    </svg>
                  </span>
                )}
              </span>

              <span class="pf-card__pitch">{p.pitch}</span>
              <span class="pf-card__tags">{p.tags.map((t) => <em>{t}</em>)}</span>
              <span class="pf-card__go">Abrir demo <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17 17 7M8 7h9v9"/></svg></span>
            </button>
          ))}
        </div>
        <p class="pf-note" data-reveal>
          Demos interativas com dados fictícios, construídas pela NOVRA para demonstração de capacidade.
        </p>
      </div>
    </section>
  </main>

  <!-- ===================== TAKEOVER FULLSCREEN ===================== -->
  <div class="pf-tk" id="pf-tk" hidden role="dialog" aria-modal="true" aria-label="Demonstração de produto">
    <div class="pf-tk__bar">
      <button class="pf-tk__back" data-action="close" type="button">← Voltar</button>
      <div class="pf-tk__mid">
        <span class="pf-tk__title" id="pf-tk-title">—</span>
        <span class="pf-tk__chip">demo interativa · dados fictícios</span>
      </div>
      <div class="pf-tk__nav">
        <button class="pf-navbtn" data-action="prev" aria-label="Demo anterior" type="button">←</button>
        <button class="pf-navbtn" data-action="next" aria-label="Próxima demo" type="button">→</button>
      </div>
    </div>
    <div class="pf-tk__stage" data-lenis-prevent>
      <DemoInsight />
      <DemoAgente />
      <DemoAtlas />
      <DemoProcessflow />
    </div>
  </div>

  <style is:global>
    /* ---------- topo / hero / grid (prefixo pf-) ---------- */
    .pf-top { position: relative; z-index: 5; padding-top: 1.6rem; }
    .pf-top__inner { display: flex; align-items: center; justify-content: space-between; gap: 1rem; }
    .pf-top__brand img { height: 38px; width: auto; display: block; }
    .pf { position: relative; z-index: 2; }
    .pf-hero { position: relative; padding: clamp(3rem, 8vh, 5rem) 0 clamp(1.2rem, 3vh, 2.4rem); }
    .pf-hero__orb { top: -30%; left: 8%; width: 44vw; height: 44vw; max-width: 620px; max-height: 620px;
      background: radial-gradient(circle, rgba(46, 107, 255, 0.16), transparent 66%); }
    .pf-hero__lead { max-width: 560px; margin-top: 1.2rem; }
    .pf-hero__lead strong { color: var(--text-1); }

    .pf-gallery { padding: 1rem 0 clamp(4rem, 9vh, 7rem); }
    .pf-grid { display: grid; grid-template-columns: 1fr; gap: 1.3rem; }
    @media (min-width: 720px) { .pf-grid { grid-template-columns: repeat(2, 1fr); } }

    .pf-card {
      text-align: left; cursor: pointer;
      display: flex; flex-direction: column; align-items: stretch;
      padding: clamp(1.4rem, 1.1rem + 1vw, 1.9rem);
      color: inherit; font: inherit;
    }
    .pf-card__num { position: absolute; top: 1.3rem; right: 1.4rem; font-family: var(--font-mono); font-size: 0.78rem; color: var(--text-3); }
    .pf-card__cat { font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--cyan-400); }
    .pf-card__name { margin-top: 0.5rem; font-family: var(--font-display); font-weight: 600; font-size: 1.5rem; letter-spacing: -0.01em; color: var(--text-1); }
    .pf-card__pitch { margin-top: 0.85rem; font-size: 0.92rem; line-height: 1.55; color: var(--text-2); }
    .pf-card__tags { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-top: 0.8rem; }
    .pf-card__tags em { font-style: normal; font-family: var(--font-mono); font-size: 0.64rem; color: var(--text-2); padding: 0.28em 0.6em; border: 1px solid var(--border); border-radius: 99px; background: var(--surface); }
    .pf-card__go { display: inline-flex; align-items: center; gap: 0.45rem; margin-top: 1rem; font-family: var(--font-display); font-weight: 600; font-size: 0.9rem; color: var(--cyan-400); transition: gap 0.4s var(--ease-out); }
    .pf-card:hover .pf-card__go { gap: 0.75rem; }

    /* preview em CSS puro dentro do card */
    .pf-prev { display: block; margin-top: 1rem; pointer-events: none; }
    .pf-prev__frame {
      display: flex; gap: 6px; height: 108px; padding: 8px;
      border: 1px solid var(--border); border-radius: 12px;
      background: #0a0b10; overflow: hidden;
    }
    .pv-side { display: flex; flex-direction: column; gap: 5px; width: 34px; flex: 0 0 auto; padding: 4px; border-right: 1px solid rgba(255,255,255,0.06); }
    .pv-side b { height: 7px; border-radius: 3px; background: rgba(255,255,255,0.1); }
    .pv-side b:first-child { background: rgba(46,107,255,0.55); }
    .pv-main { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 6px; padding: 4px; }
    .pv-kpi { height: 13px; border-radius: 4px; background: rgba(255,255,255,0.07); }
    .pv-main svg { flex: 1; width: 100%; }
    .pv-row { display: flex; align-items: center; height: 15px; border-radius: 4px; background: rgba(255,255,255,0.05); position: relative; }
    .pv-row b { position: absolute; right: 5px; width: 26px; height: 7px; border-radius: 99px; }
    .pv-row b.ok { background: rgba(121,226,160,0.5); }
    .pv-row b.cy { background: rgba(0,168,255,0.5); }
    .pv-row b.wa { background: rgba(233,194,104,0.5); }
    .pf-prev__frame--chat { flex-direction: column; justify-content: center; }
    .pv-bub { height: 15px; border-radius: 8px; width: 62%; background: rgba(255,255,255,0.07); }
    .pv-bub--out { align-self: flex-end; background: linear-gradient(120deg, rgba(46,107,255,0.55), rgba(0,168,255,0.55)); }
    .pv-bub--short { width: 38%; }
    .pv-dots { display: flex; gap: 4px; padding-left: 6px; }
    .pv-dots b { width: 5px; height: 5px; border-radius: 50%; background: rgba(255,255,255,0.35); animation: pv-tp 1.1s ease-in-out infinite; }
    .pv-dots b:nth-child(2) { animation-delay: 0.15s; } .pv-dots b:nth-child(3) { animation-delay: 0.3s; }
    @keyframes pv-tp { 50% { opacity: 0.3; transform: translateY(-2px); } }
    .pf-prev__frame--map { padding: 4px; }
    .pf-prev__frame--map svg { width: 100%; height: 100%; }

    .pf-note { margin-top: 2.2rem; text-align: center; font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.06em; color: var(--text-3); }

    /* ---------- takeover ---------- */
    .pf-tk {
      position: fixed; inset: 0; z-index: 250;
      display: flex; flex-direction: column;
      background: var(--bg-0);
      opacity: 0; transition: opacity 0.35s var(--ease-out);
    }
    .pf-tk[hidden] { display: none; }
    .pf-tk.is-open { opacity: 1; }
    .pf-tk__bar {
      display: flex; align-items: center; justify-content: space-between; gap: 0.8rem;
      padding: 0.7rem clamp(0.8rem, 2.5vw, 1.6rem);
      border-bottom: 1px solid var(--border);
      background: rgba(10, 10, 14, 0.9);
    }
    .pf-tk__back {
      font: inherit; font-size: 0.84rem; color: var(--text-2); cursor: pointer;
      border: 1px solid var(--border-strong); background: var(--surface-2); border-radius: 10px;
      padding: 0.5rem 0.9rem; transition: color 0.25s, border-color 0.25s;
      white-space: nowrap;
    }
    .pf-tk__back:hover { color: var(--text-1); border-color: var(--border-brand); }
    .pf-tk__mid { display: flex; align-items: center; gap: 0.7rem; min-width: 0; flex-wrap: wrap; justify-content: center; }
    .pf-tk__title { font-family: var(--font-display); font-weight: 600; font-size: 0.95rem; white-space: nowrap; }
    .pf-tk__chip { font-family: var(--font-mono); font-size: 0.58rem; letter-spacing: 0.06em; color: var(--text-3); border: 1px solid var(--border); border-radius: 99px; padding: 0.25em 0.7em; white-space: nowrap; }
    .pf-tk__nav { display: flex; gap: 0.45rem; }
    .pf-navbtn {
      width: 36px; height: 36px; border-radius: 10px;
      border: 1px solid var(--border-strong); background: var(--surface-2);
      color: var(--text-1); font-size: 0.9rem; cursor: pointer;
      transition: background 0.3s, border-color 0.3s;
    }
    .pf-navbtn:hover { background: var(--surface-hover); border-color: var(--border-brand); }
    .pf-tk__stage { flex: 1; min-height: 0; min-width: 0; overflow-y: auto; overscroll-behavior: contain; }
    .pf-tk__stage .demo { min-height: 100%; }
    /* display das demos (grid/flex) venceria o [hidden] da UA — regra dura aqui */
    .pf-tk__stage .demo[hidden] { display: none !important; }

    body.pf-locked { overflow: hidden; }

    @media (max-width: 640px) {
      .pf-tk__chip { display: none; }
    }
  </style>

  <script>
    import { getDemo, replay } from '../scripts/demo-utils.js';

    const slugs = ['insight', 'agente', 'atlas', 'processflow'];
    const NAMES = { insight: 'NOVRA Insight', agente: 'Agente NOVRA', atlas: 'Atlas ERP', processflow: 'ProcessFlow' };
    // links antigos continuam abrindo a demo mais próxima
    const ALIASES = { insightsphere: 'insight', datatrust: 'insight', copiloto: 'agente', cloudbridge: 'processflow' };

    const tk = document.getElementById('pf-tk');
    const stage = tk.querySelector('.pf-tk__stage');
    const title = document.getElementById('pf-tk-title');
    let current = -1;
    let isOpen = false;
    let hideT = null;
    let lastFocus = null;
    let openRaf = null;
    // fundo fica inerte com o dialog aberto (Tab/leitor de tela não escapam)
    const bgEls = () => [document.querySelector('.pf-top'), document.getElementById('main')].filter(Boolean);

    const rootOf = (slug) => document.getElementById('demo-' + slug);

    function show(idx) {
      if (!isOpen) return;
      const prev = current;
      current = (idx + slugs.length) % slugs.length;
      if (prev === current && prev !== -1) return;
      if (prev !== -1) {
        const api = getDemo(slugs[prev]);
        if (api && api.unmount) api.unmount(rootOf(slugs[prev]));
      }
      slugs.forEach((s, i) => { rootOf(s).hidden = i !== current; });
      const slug = slugs[current];
      const root = rootOf(slug);
      const api = getDemo(slug);
      if (api && api.mount) api.mount(root);
      replay(root);
      title.textContent = NAMES[slug];
      stage.scrollTop = 0;
      history.replaceState(null, '', '#' + slug);
      // se o foco estava dentro da demo que sumiu, cai pro body — devolve pro dialog
      if (!tk.contains(document.activeElement)) tk.querySelector('.pf-tk__back').focus();
    }

    function openTk(idx) {
      clearTimeout(hideT);
      isOpen = true;
      lastFocus = document.activeElement;
      tk.hidden = false;
      document.body.classList.add('pf-locked');
      bgEls().forEach((el) => { el.inert = true; });
      if (openRaf) cancelAnimationFrame(openRaf);
      openRaf = requestAnimationFrame(() => { openRaf = null; tk.classList.add('is-open'); });
      current = -1;
      show(idx);
      tk.querySelector('.pf-tk__back').focus();
    }
    function closeTk() {
      if (!isOpen) return;
      isOpen = false;
      if (current !== -1) {
        const api = getDemo(slugs[current]);
        if (api && api.unmount) api.unmount(rootOf(slugs[current]));
      }
      current = -1;
      if (openRaf) { cancelAnimationFrame(openRaf); openRaf = null; }
      tk.classList.remove('is-open');
      document.body.classList.remove('pf-locked');
      bgEls().forEach((el) => { el.inert = false; });
      clearTimeout(hideT);
      hideT = setTimeout(() => { tk.hidden = true; }, 380);
      history.replaceState(null, '', location.pathname + location.search);
      if (lastFocus && lastFocus.focus) lastFocus.focus();
    }

    /* clique delegado: controles do takeover + ações das demos */
    tk.addEventListener('click', (e) => {
      const el = e.target.closest('[data-action]');
      if (!el) return;
      const action = el.dataset.action;
      if (action === 'close') { closeTk(); return; }
      if (action === 'prev') { show(current - 1); return; }
      if (action === 'next') { show(current + 1); return; }
      if (current !== -1) {
        const api = getDemo(slugs[current]);
        if (api && api.onAction) api.onAction(action, el, rootOf(slugs[current]));
      }
    });

    document.querySelectorAll('[data-open]').forEach((btn) => {
      btn.addEventListener('click', () => openTk(slugs.indexOf(btn.dataset.open)));
    });

    document.addEventListener('keydown', (e) => {
      if (!isOpen) return;
      if (e.key === 'Escape') { closeTk(); return; }
      // trap de foco: Tab circula dentro do dialog (o fundo já está inert; isto cobre browsers sem inert)
      if (e.key === 'Tab') {
        const focusables = [...tk.querySelectorAll('button, input, [tabindex]:not([tabindex="-1"])')]
          .filter((el) => !el.disabled && el.offsetParent !== null);
        if (!focusables.length) return;
        const first = focusables[0], last = focusables[focusables.length - 1];
        if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus(); }
        else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus(); }
        else if (!tk.contains(document.activeElement)) { e.preventDefault(); first.focus(); }
        return;
      }
      if (e.target.closest('input, textarea, select, [contenteditable="true"]')) return; // digitando: setas não trocam demo
      if (e.key === 'ArrowLeft') show(current - 1);
      if (e.key === 'ArrowRight') show(current + 1);
    });

    /* deep-link (módulos das demos já executaram: modules são deferred) */
    const boot = () => {
      const h = location.hash.replace('#', '');
      const slug = ALIASES[h] || h;
      if (slugs.includes(slug)) openTk(slugs.indexOf(slug));
    };
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
    else boot();
  </script>
</Base>
