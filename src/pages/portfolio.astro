    };

    function show(idx) {
      if (!isOpen) return; // ignora setas/prev/next durante o fade-out (não recria hash)
      current = (idx + slugs.length) % slugs.length;
      const slug = slugs[current];
      details.forEach((d, i) => { d.hidden = i !== current; });
      // desmonta as telas dos outros projetos: evita ids de gradiente duplicados
      // (url(#pfgrad) resolve pro 1º do documento — se estiver em subtree oculto, não pinta)
      // e não deixa animação rodando escondida
      slugs.forEach((s) => { if (s !== slug) { const b = document.getElementById('scr-' + s); if (b) b.innerHTML = ''; } });
      const body = document.getElementById('scr-' + slug);
      // re-monta a tela p/ reiniciar todas as animações a cada abertura
      body.innerHTML = SCREENS[slug];
      const detail = details[current];
      detail.classList.remove('play');
      void detail.offsetWidth;
      detail.classList.add('play');
      // counters injetados agora: anima direto (o observer global só pegou os do build)
      body.querySelectorAll('[data-count]').forEach((el) => {
        const target = parseFloat(el.dataset.count || '0');
        const dec = parseInt(el.dataset.decimals || '0', 10);
        const suf = el.dataset.suffix || '';
        const t0 = performance.now();
        const tick = (now) => {
          const p = Math.min((now - t0) / 1400, 1);
          const eased = 1 - Math.pow(1 - p, 3);
          el.textContent = (target * eased).toLocaleString('pt-BR', { minimumFractionDigits: dec, maximumFractionDigits: dec }) + suf;
          if (p < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      });
      if (slug === 'insightsphere') setTimeout(typeAsk, 350);
      const sheet = overlay.querySelector('.pf-sheet');
      if (sheet) sheet.scrollTop = 0;
      history.replaceState(null, '', '#' + slug);
    }

    function openModal(idx) {
      clearTimeout(hideT); // reabertura rápida: cancela o esconder pendente do fechamento anterior
      isOpen = true;
      lastFocus = document.activeElement;
      overlay.hidden = false;
      document.body.classList.add('pf-locked');
      requestAnimationFrame(() => overlay.classList.add('is-open'));
      show(idx);
      const closeBtn = overlay.querySelector('.pf-navbtn--close');
      if (closeBtn) closeBtn.focus();
    }
    function closeModal() {
      isOpen = false;
      overlay.classList.remove('is-open');
      document.body.classList.remove('pf-locked');
      clearInterval(typerT);
      clearTimeout(hideT);
      hideT = setTimeout(() => { overlay.hidden = true; }, 420);
      history.replaceState(null, '', location.pathname);
      if (lastFocus && lastFocus.focus) lastFocus.focus();
    }

    document.querySelectorAll('[data-open]').forEach((btn) => {
      btn.addEventListener('click', () => openModal(slugs.indexOf(btn.dataset.open)));
    });
    overlay.querySelectorAll('[data-close]').forEach((el) => el.addEventListener('click', closeModal));
    document.getElementById('pf-prev').addEventListener('click', () => show(current - 1));
    document.getElementById('pf-next').addEventListener('click', () => show(current + 1));
    document.addEventListener('keydown', (e) => {
      if (!isOpen) return;
      if (e.key === 'Escape') closeModal();
      if (e.key === 'ArrowLeft') show(current - 1);
      if (e.key === 'ArrowRight') show(current + 1);
    });

    /* deep-link: /portfolio#atlas abre direto */
    const h = location.hash.replace('#', '');
    if (slugs.includes(h)) openModal(slugs.indexOf(h));
  </script>
</Base>
