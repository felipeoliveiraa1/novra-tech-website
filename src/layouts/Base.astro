---
import '@fontsource-variable/space-grotesk';
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
}
const {
  title = 'NOVRA — Sistemas inteligentes para a próxima era',
  description = 'A NOVRA desenvolve soluções em tecnologia, IA, automação, cloud e sistemas digitais para empresas que buscam performance, segurança e escala.',
  noindex = false,
} = Astro.props;
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.pathname;
---
<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#0a0a0c" />
    <meta name="generator" content={Astro.generator} />

    <!-- No-JS fallback: never hide content if scripts fail/are disabled -->
    <noscript>
      <style>
        [data-reveal] { opacity: 1 !important; transform: none !important; filter: none !important; }
        .hw { animation: none !important; opacity: 1 !important; }
        .hero__canvas { opacity: 1 !important; }
        .cursor, .scroll-progress { display: none !important; }
      </style>
    </noscript>

    <!-- Icons -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/brand/novra-icon-512.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:site_name" content="NOVRA" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/brand/novra-icon-512.png" />
    <meta name="twitter:card" content="summary_large_image" />

    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Organization',
      name: 'NOVRA',
      description,
      url: 'https://novratech.com.br',
      logo: 'https://novratech.com.br/brand/novra-icon-512.png',
      sameAs: ['https://www.instagram.com/novratech.oficial'],
    })} />

    <!-- intro de marca: roda 1x por sessão; decide ANTES do primeiro paint -->
    <script is:inline>
      try { if (sessionStorage.getItem('novra-seen')) document.documentElement.classList.add('no-intro'); } catch (e) {}
    </script>
  </head>
  <body>
    <a href="#main" class="skip-link">Pular para o conteúdo</a>

    <!-- Preloader de marca (auto-sai via animação CSS; JS só marca a sessão) -->
    <div class="intro" id="intro" aria-hidden="true">
      <div class="intro__mark">
        <img src="/brand/novra-icon-512.png" alt="" width="72" height="72" />
        <span class="intro__line"></span>
      </div>
    </div>

    <!-- Ambient background -->
    <div class="bg-canvas" aria-hidden="true">
      <div class="bg-grid"></div>
    </div>

    <!-- Scroll progress -->
    <div class="scroll-progress" aria-hidden="true"><span id="scroll-bar"></span></div>

    <!-- Custom cursor -->
    <div class="cursor" id="cursor" aria-hidden="true">
      <div class="cursor__dot"></div>
      <div class="cursor__ring"></div>
    </div>

    <slot />

    <div class="grain" aria-hidden="true"></div>

    <script src="../scripts/main.js"></script>

    <style>
      /* ---- Intro de marca (preloader) ---- */
      .intro {
        position: fixed; inset: 0; z-index: 400;
        display: flex; align-items: center; justify-content: center;
        background: var(--bg-0);
        pointer-events: none; /* nunca bloqueia clique, é só visual */
        animation: intro-out 0.7s var(--ease-out) 1.5s forwards;
      }
      .intro__mark { display: flex; flex-direction: column; align-items: center; gap: 1.1rem; }
      .intro__mark img {
        width: 72px; height: 72px;
        filter: drop-shadow(0 0 26px rgba(46, 107, 255, 0.55));
        animation: intro-mark 0.9s var(--ease-out) both;
      }
      .intro__line {
        width: 120px; height: 2px; border-radius: 2px;
        background: var(--grad-signature);
        box-shadow: 0 0 14px rgba(0, 168, 255, 0.5);
        transform: scaleX(0); transform-origin: left center;
        animation: intro-line 1.1s var(--ease-out) 0.25s both;
      }
      @keyframes intro-mark {
        from { opacity: 0; transform: scale(0.86); filter: drop-shadow(0 0 0 rgba(46,107,255,0)) blur(8px); }
        to { opacity: 1; transform: none; filter: drop-shadow(0 0 26px rgba(46,107,255,0.55)); }
      }
      @keyframes intro-line { from { transform: scaleX(0); } to { transform: scaleX(1); } }
      @keyframes intro-out { to { opacity: 0; visibility: hidden; } }
      /* já viu nesta sessão, ou prefere menos movimento → sem intro */
      html.no-intro .intro { display: none; }
      @media (prefers-reduced-motion: reduce) { .intro { display: none; } }

      .bg-canvas {
        position: fixed;
        inset: 0;
        z-index: 0;
        overflow: hidden;
        pointer-events: none;
        background: var(--bg-0); /* preto é o palco */
      }
      .bg-grid {
        position: absolute;
        inset: -2px;
        background-image:
          linear-gradient(rgba(255, 255, 255, 0.016) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255, 255, 255, 0.016) 1px, transparent 1px);
        background-size: 72px 72px;
        -webkit-mask-image: linear-gradient(180deg, rgba(0,0,0,0.6), transparent 55%);
        mask-image: linear-gradient(180deg, rgba(0,0,0,0.6), transparent 55%);
      }
      .scroll-progress {
        position: fixed;
        top: 0; left: 0; right: 0;
        height: 2px;
        z-index: 120;
        background: transparent;
      }
      #scroll-bar {
        display: block;
        height: 100%;
        width: 0%;
        background: var(--grad-brand);
        box-shadow: 0 0 12px rgba(0, 168, 255, 0.6);
        transition: width 0.1s linear;
      }
      /* Custom cursor */
      .cursor { position: fixed; top: 0; left: 0; z-index: 300; pointer-events: none; mix-blend-mode: difference; opacity: 0; transition: opacity 0.3s; }
      .cursor__dot {
        position: absolute; top: 0; left: 0;
        width: 6px; height: 6px; border-radius: 50%; background: #fff;
        transform: translate(-50%, -50%);
      }
      .cursor__ring {
        position: absolute; top: 0; left: 0;
        width: 38px; height: 38px; border-radius: 50%;
        border: 1px solid rgba(255, 255, 255, 0.6);
        transform: translate(-50%, -50%);
        transition: width 0.3s var(--ease-out), height 0.3s var(--ease-out), border-color 0.3s;
      }
      .cursor.is-hover .cursor__ring { width: 56px; height: 56px; border-color: #fff; }
      @media (hover: hover) and (pointer: fine) {
        body.has-cursor { cursor: none; }
        body.has-cursor a, body.has-cursor button { cursor: none; }
      }
      @media (max-width: 768px) { .cursor { display: none; } }
      @media (prefers-reduced-motion: reduce) {
        .orb-a, .orb-b { animation: none; }
      }
    </style>
  </body>
</html>
